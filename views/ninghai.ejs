<style>
/* ===== 宁海页 · 海洋蓝风格 ===== */
:root {
  --nh-blue: #1a6b8a;
  --nh-light: #e8f4f8;
  --nh-accent: #e67e22;
  --nh-green: #4a8c6f;
}

/* Hero */
.nh-hero {
  position: relative;
  padding: 60px 0 50px;
  background: linear-gradient(135deg, #1a6b8a 0%, #2980b9 50%, #1a5276 100%);
  color: #fff;
  text-align: center;
  overflow: hidden;
}
.nh-hero-bg { position: absolute; inset: 0; pointer-events: none; }
.nh-wave {
  position: absolute;
  width: 200%; height: 60px;
  background: rgba(255,255,255,0.04);
  border-radius: 50%;
  animation: nhWave 6s ease-in-out infinite;
}
.nh-wave-1 { bottom: -20px; left: -50%; animation-delay: 0s; }
.nh-wave-2 { bottom: -30px; left: -30%; animation-delay: -2s; opacity: 0.5; }
@keyframes nhWave { 0%,100%{transform:translateX(0)} 50%{transform:translateX(20px)} }
.nh-hero-inner { position: relative; z-index: 1; }
.nh-badge {
  display: inline-block;
  background: rgba(255,255,255,0.15);
  border: 1px solid rgba(255,255,255,0.2);
  padding: 4px 16px;
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  margin-bottom: 12px;
}
.nh-title {
  font-size: clamp(2.5rem, 6vw, 4rem);
  font-weight: 900;
  letter-spacing: 0.05em;
  margin-bottom: 6px;
}
.nh-sub {
  font-size: clamp(0.9rem, 1.5vw, 1.1rem);
  color: rgba(255,255,255,0.6);
  font-weight: 300;
  max-width: 500px;
  margin: 0 auto 20px;
}
.nh-stats {
  display: flex;
  justify-content: center;
  gap: 12px;
  flex-wrap: wrap;
}
.nh-stat-item {
  display: flex;
  align-items: center;
  gap: 6px;
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.1);
  padding: 6px 14px;
  font-size: 0.82rem;
}
.nh-stat-val { font-size: 1.1rem; }
.nh-stat-label { color: rgba(255,255,255,0.7); }

/* Sections */
.nh-section {
  padding: 40px 0;
  border-bottom: 2px solid var(--border);
}
.nh-section-alt { background: var(--bg-card); }
.nh-section-title {
  font-size: clamp(1.1rem, 2.5vw, 1.4rem);
  font-weight: 800;
  margin-bottom: 20px;
  color: var(--text);
}

/* Map */
.nh-map-wrap {
  border-radius: 12px;
  overflow: hidden;
  margin-bottom: 12px;
}
.nh-map-desc {
  color: var(--text-secondary);
  font-size: 0.9rem;
  line-height: 1.7;
}

/* Cards */
.nh-card-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
}
.nh-card {
  background: var(--bg);
  border: 2px solid var(--border);
  padding: 20px;
  transition: transform 0.2s;
}
.nh-card:hover { transform: translateY(-3px); }
.nh-card-icon { font-size: 2rem; margin-bottom: 8px; }
.nh-card h3 { font-size: 1rem; font-weight: 700; margin-bottom: 10px; color: var(--text); }
.nh-card ul { list-style: none; padding: 0; margin: 0; }
.nh-card li {
  font-size: 0.82rem;
  color: var(--text-secondary);
  line-height: 1.6;
  padding: 3px 0;
  border-bottom: 1px solid var(--border);
}
.nh-card li:last-child { border-bottom: none; }

/* Feature */
.nh-feature {
  display: flex;
  gap: 20px;
  background: var(--bg);
  border: 2px solid var(--border);
  padding: 24px;
}
.nh-feature-icon { font-size: 2.5rem; flex-shrink: 0; }
.nh-feature-body p {
  font-size: 0.9rem;
  color: var(--text-secondary);
  line-height: 1.8;
  margin-bottom: 8px;
}
.nh-feature-body p:last-child { margin-bottom: 0; }
.nh-feature-body strong { color: var(--text); }

/* Travel grid */
.nh-travel-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
}
.nh-travel-item {
  display: flex;
  flex-direction: column;
  gap: 6px;
  background: var(--bg);
  border: 2px solid var(--border);
  padding: 18px 16px;
  transition: transform 0.2s;
}
.nh-travel-item:hover {
  transform: translateY(-3px);
  border-color: var(--accent, #3498db);
}
.nh-travel-icon { font-size: 1.5rem; }
.nh-travel-item strong { font-size: 0.9rem; color: var(--text); }
.nh-travel-item span { font-size: 0.78rem; color: var(--text-secondary); line-height: 1.4; }

/* Town section */
.nh-town {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24px;
  align-items: start;
}
.nh-town-text p {
  font-size: 0.9rem;
  color: var(--text-secondary);
  line-height: 1.8;
  margin-bottom: 10px;
}
.nh-town-text strong { color: var(--text); }
.nh-feature-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 14px;
}
.nh-feature-list span {
  display: inline-block;
  padding: 4px 12px;
  background: var(--bg-card);
  border: 1px solid var(--border);
  font-size: 0.78rem;
  color: var(--text-secondary);
}
.nh-photo-placeholder {
  width: 100%;
  aspect-ratio: 4/3;
  background: var(--bg-card);
  border: 2px dashed var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1rem;
  color: var(--text-muted);
}

/* Album empty */
.nh-empty-album {
  text-align: center;
  padding: 40px 20px;
  background: var(--bg-card);
  border: 2px dashed var(--border);
  color: var(--text-muted);
  font-size: 0.9rem;
}

/* ===== Dark theme overrides ===== */
body:not(.light-theme) .nh-card { background: var(--bg-card); }
body:not(.light-theme) .nh-feature { background: var(--bg-card); }
body:not(.light-theme) .nh-travel-item { background: var(--bg-card); }
body:not(.light-theme) .nh-photo-placeholder { background: var(--bg); }

/* ===== Responsive ===== */
@media (max-width: 768px) {
  .nh-hero { padding: 40px 0 30px; }
  .nh-stats { gap: 6px; }
  .nh-stat-item { font-size: 0.72rem; padding: 4px 10px; }
  .nh-card-grid, .nh-travel-grid { grid-template-columns: 1fr; }
  .nh-town { grid-template-columns: 1fr; }
  .nh-feature { flex-direction: column; }
  .nh-feature-icon { text-align: center; }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // 宁海地图（Leaflet）
  if (typeof L !== 'undefined' && document.getElementById('ninghaiMap')) {
    var map = L.map('ninghaiMap').setView([29.35, 121.45], 10);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; OpenStreetMap'
    }).addTo(map);
    // 宁海县城
    L.marker([29.29, 121.43]).addTo(map).bindPopup('🏙️ 宁海县城');
    // 长街镇
    L.marker([29.38, 121.62]).addTo(map).bindPopup('🌟 长街镇 · 我长大的地方');
    // 石桥头村（长街镇附近，约略坐标）
