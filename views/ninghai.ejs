<%- include('partials/header') %>

<!-- ===== Hero ===== -->
<section class="nh-hero">
  <div class="nh-hero-waves">
    <div class="nh-wave nh-wave-1"></div>
    <div class="nh-wave nh-wave-2"></div>
  </div>
  <div class="container nh-hero-inner">
    <div class="nh-hero-content">
      <div class="nh-hero-badge">我的家乡</div>
      <h1 class="nh-hero-title">宁海</h1>
      <p class="nh-hero-sub">浙江东部 · 一座有山有海的小城</p>
      <div class="nh-hero-meta">
        <span>📍 宁波南部</span>
        <span>👥 约70万人</span>
        <span>📖 徐霞客开篇地</span>
      </div>
    </div>
  </div>
</section>

<!-- ===== 速览 ===== -->
<section class="nh-section nh-quick">
  <div class="container">
    <div class="nh-quick-grid">
      <div class="nh-quick-item">
        <div class="nh-quick-icon">🗺️</div>
        <div class="nh-quick-body">
          <strong>宁海在哪里？</strong>
          <span>浙江省东部沿海，象山港和三门湾之间，宁波市下辖县</span>
        </div>
      </div>
      <div class="nh-quick-item">
        <div class="nh-quick-icon">📜</div>
        <div class="nh-quick-body">
          <strong>为什么有名？</strong>
          <span>《徐霞客游记》开篇地，中国旅游日发祥地，5月19日</span>
        </div>
      </div>
      <div class="nh-quick-item">
        <div class="nh-quick-icon">🏔️</div>
        <div class="nh-quick-body">
          <strong>有什么特别？</strong>
          <span>天台山与四明山交汇，山海兼具，森林温泉闻名</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ===== 地图 ===== -->
<section class="nh-section">
  <div class="container">
    <h2 class="nh-section-title"><span class="nh-st-icon">🗺️</span> 地理位置</h2>
    <div id="ninghaiMap" style="width:100%;height:380px;border-radius:12px;overflow:hidden;border:2px solid var(--border);"></div>
  </div>
</section>

<!-- ===== 风土人情 ===== -->
<section class="nh-section nh-alt">
  <div class="container">
    <h2 class="nh-section-title"><span class="nh-st-icon">🎭</span> 风土人情</h2>
    <div class="nh-cards">
      <!-- 美食 -->
      <div class="nh-card" style="--card-accent:#e67e22">
        <div class="nh-card-top">
          <span class="nh-card-icon">🦪</span>
          <h3>美食</h3>
        </div>
        <div class="nh-card-items">
          <div class="nh-card-item"><span class="nh-dot" style="background:#e67e22"></span>长街蛏子 — 国家地理标志，被誉为"这个星球上最好吃的蛏子"</div>
          <div class="nh-card-item"><span class="nh-dot" style="background:#e67e22"></span>岔路麦饼 — 宁海传统小吃，香脆可口</div>
          <div class="nh-card-item"><span class="nh-dot" style="background:#e67e22"></span>前童三宝 — 豆腐、香干、空心腐</div>
          <div class="nh-card-item"><span class="nh-dot" style="background:#e67e22"></span>宁海海鲜 — 黄鱼、带鱼、梭子蟹</div>
        </div>
      </div>
      <!-- 民俗 -->
      <div class="nh-card" style="--card-accent:#c0392b">
        <div class="nh-card-top">
          <span class="nh-card-icon">🏮</span>
          <h3>民俗</h3>
        </div>
        <div class="nh-card-items">
          <div class="nh-card-item"><span class="nh-dot" style="background:#c0392b"></span>十里红妆 — 宁海传统婚俗，国家级非遗</div>
          <div class="nh-card-item"><span class="nh-dot" style="background:#c0392b"></span>泥金彩漆 — 国家级非物质文化遗产</div>
          <div class="nh-card-item"><span class="nh-dot" style="background:#c0392b"></span>宁海平调 — 地方戏曲，别具一格</div>
          <div class="nh-card-item"><span class="nh-dot" style="background:#c0392b"></span>舞龙舞狮 — 节庆必备，热闹非凡</div>
        </div>
      </div>
      <!-- 方言 -->
      <div class="nh-card" style="--card-accent:#2980b9">
        <div class="nh-card-top">
          <span class="nh-card-icon">🗣️</span>
          <h3>方言</h3>
        </div>
        <div class="nh-card-items">
          <div class="nh-card-item"><span class="nh-dot" style="background:#2980b9"></span>宁海话 — 吴语太湖片甬江小片</div>
          <div class="nh-card-item"><span class="nh-dot" style="background:#2980b9"></span>长街口音与县城略有不同</div>
          <div class="nh-card-item"><span class="nh-dot" style="background:#2980b9"></span>吃茶(喝茶) · 困觉(睡觉) · 侬好(你好)</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ===== 徐霞客开游节 ===== -->
<section class="nh-section">
  <div class="container">
    <h2 class="nh-section-title"><span class="nh-st-icon">🏆</span> 徐霞客开游节</h2>
    <div class="nh-feature-box">
      <div class="nh-feature-quote">
        <blockquote>「癸丑之三月晦，自宁海出西门，云散日朗，人意山光，俱有喜态。」</blockquote>
        <cite>——《徐霞客游记》开篇</cite>
      </div>
      <p>1613年5月19日，徐霞客从宁海西门出发，开始了他的万里遐征。宁海因此被公认为<strong>徐霞客游记开篇地</strong>，也是<strong>中国旅游日</strong>（5月19日）的发祥地。</p>
      <div class="nh-feature-tags">
        <span>🎉 每年5月19日</span>
        <span>🥾 霞客古道徒步</span>
        <span>🎭 民俗表演</span>
        <span>🍢 美食集市</span>
      </div>
    </div>
  </div>
</section>

<!-- ===== 旅游推荐 ===== -->
<section class="nh-section nh-alt">
  <div class="container">
    <h2 class="nh-section-title"><span class="nh-st-icon">🏝️</span> 旅游推荐</h2>
    <div class="nh-spots">
      <div class="nh-spot" style="--spot-c:#e67e22">
        <div class="nh-spot-icon">🏯</div>
        <div class="nh-spot-info">
          <strong>前童古镇</strong>
          <span>明清古建筑群，小桥流水，"回字"八卦街巷</span>
        </div>
      </div>
      <div class="nh-spot" style="--spot-c:#27ae60">
        <div class="nh-spot-icon">♨️</div>
        <div class="nh-spot-info">
          <strong>森林温泉</strong>
          <span>南溪温泉，天然氧吧，华东最好的温泉之一</span>
        </div>
      </div>
      <div class="nh-spot" style="--spot-c:#3498db">
        <div class="nh-spot-icon">🌲</div>
        <div class="nh-spot-info">
          <strong>浙东大峡谷</strong>
          <span>峡谷幽深，飞瀑流泉，适合徒步探险</span>
        </div>
      </div>
      <div class="nh-spot" style="--spot-c:#8e44ad">
        <div class="nh-spot-icon">🪨</div>
        <div class="nh-spot-info">
          <strong>伍山石窟</strong>
          <span>千年采石遗迹，洞窟奇观，在长街镇境内</span>
        </div>
      </div>
      <div class="nh-spot" style="--spot-c:#2c3e50">
        <div class="nh-spot-icon">🏝️</div>
        <div class="nh-spot-info">
          <strong>强蛟群岛</strong>
          <span>象山港内12座岛屿，海钓天堂，"小普陀"</span>
        </div>
      </div>
      <div class="nh-spot" style="--spot-c:#c0392b">
        <div class="nh-spot-icon">⛰️</div>
        <div class="nh-spot-info">
          <strong>梁皇山</strong>
          <span>徐霞客曾到访，山势险峻，霞客古道起点</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ===== 长街镇 ===== -->
<section class="nh-section">
  <div class="container">
    <h2 class="nh-section-title"><span class="nh-st-icon">🌟</span> 长街镇 · 我长大的地方</h2>
    <div class="nh-town-box">
      <div class="nh-town-intro">
        <div class="nh-town-icon">📍</div>
        <div>
          <p>长街镇位于宁海县东部，濒临象山港，是一个山海兼具的美丽小镇。这里有绵长的海岸线和广阔的滩涂，是宁海最重要的渔业乡镇之一。</p>
          <p><strong>长街蛏子</strong>是国家地理标志产品，被《舌尖上的中国》导演陈晓卿称为<strong>"这个星球上最好吃的蛏子"</strong>。每年农历三四月蛏子最肥美的季节，远近食客慕名而来。</p>
        </div>
      </div>
      <div class="nh-town-tags">
        <span>📍 宁海东部 · 象山港畔</span>
        <span>🦪 长街蛏子（国家地理标志）</span>
        <span>🏖️ 海岸滩涂 · 赶海拾贝</span>
        <span>🌅 海上日出 · 渔舟唱晚</span>
      </div>
    </div>
  </div>
</section>

<!-- ===== 石桥头村 ===== -->
<section class="nh-section nh-alt" style="border-bottom:none">
  <div class="container">
    <h2 class="nh-section-title"><span class="nh-st-icon">🌳</span> 石桥头村 · 我的老家</h2>
    <div class="nh-village">
      <div class="nh-village-card">
        <div class="nh-village-icon">🌳</div>
        <p>石桥头村是长街镇下辖的一个小村庄，也是我出生长大的地方。村子不大，百来户人家，但承载了我全部的童年记忆。</p>
      </div>
      <div class="nh-village-card">
        <div class="nh-village-icon">🌾</div>
        <p>村口有一棵大樟树，夏天全村人都在树下乘凉。稻田里抓青蛙，池塘边钓小龙虾——这些都是最珍贵的回忆。</p>
      </div>
      <div class="nh-village-card">
        <div class="nh-village-icon">🏖️</div>
        <p>小时候最开心的事就是去滩涂上挖蛏子、捉螃蟹。光着脚踩在泥滩上，感受海风的咸味，那是家乡的味道。</p>
      </div>
    </div>
  </div>
</section>

<style>
/* ===== 宁海 · 深蓝海洋风 ===== */
.nh-hero {
  position: relative;
  padding: 80px 0 70px;
  background: linear-gradient(135deg, #0c2340 0%, #1a5276 30%, #2980b9 70%, #1a6b8a 100%);
  color: #fff;
  text-align: center;
  overflow: hidden;
}
.nh-hero-waves { position: absolute; inset: 0; pointer-events: none; }
.nh-wave {
  position: absolute;
  width: 200%; height: 80px;
  background: rgba(255,255,255,0.03);
  border-radius: 45%;
  animation: nhWave 7s ease-in-out infinite;
}
.nh-wave-1 { bottom: -20px; left: -50%; animation-delay: 0s; }
.nh-wave-2 { bottom: -35px; left: -30%; animation-delay: -2.5s; opacity: 0.4; }
@keyframes nhWave { 0%,100%{transform:translateX(0) rotate(0)} 50%{transform:translateX(30px) rotate(1deg)} }
.nh-hero-inner { position: relative; z-index: 1; }
.nh-hero-content { max-width: 600px; margin: 0 auto; }
.nh-hero-badge {
  display: inline-block;
  background: rgba(255,255,255,0.1);
  border: 1px solid rgba(255,255,255,0.15);
  padding: 4px 18px;
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  margin-bottom: 14px;
}
.nh-hero-title {
  font-size: clamp(3rem, 8vw, 5rem);
  font-weight: 900;
  letter-spacing: 0.06em;
  line-height: 1;
  margin-bottom: 8px;
  text-shadow: 0 2px 20px rgba(0,0,0,0.2);
}
.nh-hero-sub {
  font-size: clamp(0.9rem, 1.8vw, 1.1rem);
  color: rgba(255,255,255,0.55);
  font-weight: 300;
  letter-spacing: 0.02em;
  margin-bottom: 18px;
}
.nh-hero-meta {
  display: flex;
  justify-content: center;
  gap: 10px;
  flex-wrap: wrap;
}
.nh-hero-meta span {
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.08);
  padding: 5px 14px;
  font-size: 0.78rem;
  color: rgba(255,255,255,0.7);
}

/* Quick facts */
.nh-quick { padding: 28px 0; }
.nh-quick-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
}
.nh-quick-item {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  background: var(--bg-card);
  border: 1px solid var(--border);
  padding: 16px;
}
.nh-quick-icon { font-size: 1.5rem; flex-shrink: 0; margin-top: 2px; }
.nh-quick-body strong { display: block; font-size: 0.85rem; margin-bottom: 2px; color: var(--text); }
.nh-quick-body span { font-size: 0.78rem; color: var(--text-secondary); line-height: 1.5; }

/* Section titles */
.nh-section { padding: 40px 0; border-bottom: 1px solid var(--border); }
.nh-alt { background: var(--bg-card); }
.nh-section-title {
  font-size: clamp(1.1rem, 2vw, 1.35rem);
  font-weight: 800;
  margin-bottom: 20px;
  color: var(--text);
  display: flex;
  align-items: center;
  gap: 8px;
}
.nh-st-icon { font-size: 1.2rem; }

/* Culture cards */
.nh-cards {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
}
.nh-card {
  background: var(--bg);
  border: 1px solid var(--border);
  padding: 20px;
  transition: transform 0.25s, box-shadow 0.25s;
}
.nh-card:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(0,0,0,0.06); }
.nh-card-top {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 14px;
  padding-bottom: 10px;
  border-bottom: 2px solid var(--card-accent, #2980b9);
}
.nh-card-icon { font-size: 1.6rem; }
.nh-card-top h3 { font-size: 0.95rem; font-weight: 700; color: var(--text); }
.nh-card-items { display: flex; flex-direction: column; gap: 6px; }
.nh-card-item {
  display: flex;
  align-items: flex-start;
  gap: 6px;
  font-size: 0.82rem;
  color: var(--text-secondary);
  line-height: 1.5;
}
.nh-dot {
  display: inline-block;
  width: 6px; height: 6px;
  border-radius: 50%;
  margin-top: 7px;
  flex-shrink: 0;
}

/* Feature box */
.nh-feature-box {
  background: var(--bg);
  border: 1px solid var(--border);
  padding: 28px;
}
.nh-feature-quote {
  text-align: center;
  padding: 20px;
  margin-bottom: 16px;
  border-left: 3px solid #c0392b;
  background: var(--bg-card);
}
.nh-feature-quote blockquote {
  font-size: clamp(0.95rem, 1.5vw, 1.1rem);
  font-weight: 600;
  color: var(--text);
  line-height: 1.7;
  font-style: italic;
}
.nh-feature-quote cite {
  display: block;
  margin-top: 6px;
  font-size: 0.78rem;
  color: var(--text-muted);
  font-style: normal;
}
.nh-feature-box p {
  font-size: 0.9rem;
  color: var(--text-secondary);
  line-height: 1.8;
  margin-bottom: 14px;
}
.nh-feature-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-top: 12px;
}
.nh-feature-tags span {
  padding: 4px 12px;
  background: var(--bg-card);
  border: 1px solid var(--border);
  font-size: 0.78rem;
  color: var(--text-secondary);
}

/* Travel spots */
.nh-spots { display: flex; flex-direction: column; gap: 8px; }
.nh-spot {
  display: flex;
  align-items: center;
  gap: 14px;
  background: var(--bg);
  border: 1px solid var(--border);
  padding: 14px 18px;
  transition: transform 0.2s, border-color 0.2s;
  border-left: 3px solid var(--spot-c, #2980b9);
}
.nh-spot:hover { transform: translateX(4px); }
.nh-spot-icon { font-size: 1.4rem; flex-shrink: 0; }
.nh-spot-info strong { display: block; font-size: 0.88rem; color: var(--text); margin-bottom: 1px; }
.nh-spot-info span { font-size: 0.78rem; color: var(--text-secondary); line-height: 1.4; }

/* Town box */
.nh-town-box { background: var(--bg); border: 1px solid var(--border); padding: 24px; }
.nh-town-intro {
  display: flex;
  gap: 14px;
  margin-bottom: 16px;
}
.nh-town-icon { font-size: 2rem; flex-shrink: 0; }
.nh-town-intro p {
  font-size: 0.9rem;
  color: var(--text-secondary);
  line-height: 1.8;
  margin-bottom: 8px;
}
.nh-town-intro p:last-child { margin-bottom: 0; }
.nh-town-intro strong { color: var(--text); }
.nh-town-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}
.nh-town-tags span {
  padding: 4px 14px;
  background: var(--bg-card);
  border: 1px solid var(--border);
  font-size: 0.78rem;
  color: var(--text-secondary);
}

/* Village cards */
.nh-village {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
}
.nh-village-card {
  background: var(--bg);
  border: 1px solid var(--border);
  padding: 24px 20px;
  text-align: center;
  transition: transform 0.25s;
}
.nh-village-card:hover { transform: translateY(-4px); }
.nh-village-icon { font-size: 2.2rem; margin-bottom: 12px; }
.nh-village-card p {
  font-size: 0.85rem;
  color: var(--text-secondary);
  line-height: 1.7;
  margin: 0;
}

/* ===== Dark ===== */
body:not(.light-theme) .nh-card { background: var(--bg-card); }
body:not(.light-theme) .nh-feature-box { background: var(--bg-card); }
body:not(.light-theme) .nh-spot { background: var(--bg-card); }
body:not(.light-theme) .nh-town-box { background: var(--bg-card); }
body:not(.light-theme) .nh-village-card { background: var(--bg-card); }
body:not(.light-theme) .nh-quick-item { background: var(--bg); }

/* ===== Responsive ===== */
@media (max-width: 768px) {
  .nh-hero { padding: 50px 0 40px; }
  .nh-quick-grid { grid-template-columns: 1fr; }
  .nh-cards { grid-template-columns: 1fr; }
  .nh-village { grid-template-columns: 1fr; }
  .nh-hero-meta { gap: 6px; }
  .nh-hero-meta span { font-size: 0.7rem; padding: 3px 10px; }
}
</style>

<!-- Leaflet 地图 -->
<link rel="stylesheet" href="/css/leaflet.css" />
<script src="/js/leaflet.min.js"></script>
<script>
window.addEventListener('load', function() {
  setTimeout(function() {
    var el = document.getElementById('ninghaiMap');
    if (typeof L !== 'undefined' && el) {
      try {
        var map = L.map(el, { zoomControl: true, attributionControl: false }).setView([29.35, 121.45], 10);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { maxZoom: 18 }).addTo(map);
        L.marker([29.29, 121.43]).addTo(map).bindPopup('🏙️ 宁海县城');
        L.marker([29.38, 121.62]).addTo(map).bindPopup('🌟 长街镇');
        L.marker([29.37, 121.63]).addTo(map).bindPopup('🌳 石桥头村');
      } catch(e) { console.log('Map error:', e); }
    }
  }, 500);
});
</script>

