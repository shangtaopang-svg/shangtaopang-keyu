<%- include('partials/header') %>

<section class="page-header">
  <div class="container">
    <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px">
      <div>
        <h1 class="page-title"><%= album.title %></h1>
        <%
          var hasVideo = photos.some(function(p) { return (p.filename || '').match(/\.(mp4|m4v|webm)$/i); });
          var allVideo = photos.every(function(p) { return (p.filename || '').match(/\.(mp4|m4v|webm)$/i); });
          var unit = allVideo ? '个视频' : (hasVideo ? '个媒体' : '张照片');
        %>
        <p class="page-desc" data-zh="<%= album.description || '' %> <% if (album.year) { %>· <%= album.year %><% } %> · <%= photos.length %> <%= unit %>" data-en="<%= album.description || '' %> <% if (album.year) { %>· <%= album.year %><% } %> · <%= photos.length %> <%= allVideo ? 'videos' : (hasVideo ? 'media' : 'photos') %>"><%= album.description || '' %> <% if (album.year) { %>· <%= album.year %><% } %> · <%= photos.length %> <%= unit %></p>
      </div>
      <a href="/gallery" class="btn btn-outline btn-sm" data-zh="← 返回影集" data-en="← Back to Gallery">← 返回影集</a>
    </div>
  </div>
</section>

<% if (allVideo) { %>
<style>
.photo-grid { column-count: 2; max-width: 800px; margin: 0 auto; }
.photo-item video { border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.15); }
.photo-play-btn { width: 56px; height: 56px; font-size: 1.5rem; }
@media (max-width: 768px) { .photo-grid { column-count: 1; } }
</style>
<% } %>

<section class="section">
  <div class="container">
    <% if (photos.length === 0) { %>
      <div class="empty-state">
        <span class="empty-icon">📸</span>
        <h3 data-zh="暂无照片" data-en="No photos yet">暂无照片</h3>
      </div>
    <% } else { %>
      <div class="photo-grid" id="photoGrid">
        <% photos.forEach(p => { %>
          <div class="photo-item" onclick="<%= (p.filename || '').match(/\.(mp4|m4v|webm)$/i) ? '' : 'openViewer(this)' %>">
            <% if ((p.filename || '').match(/\.(mp4|m4v|webm)$/i)) { %>
              <video src="<%= p.filename %>" style="width:100%;height:100%;object-fit:cover" preload="metadata" onclick="this.paused ? this.play() : this.pause()"></video>
              <div class="photo-play-btn">▶</div>
            <% } else { %>
              <img src="<%= p.filename.replace('/uploads/albums/', '/uploads/albums/thumbs/') %>" data-full="<%= p.filename %>" alt="<%= p.original_name || '' %>" loading="lazy" decoding="async">
            <% } %>
            <div class="photo-desc">
              <% if (p.description) { %><span><%= p.description %></span><% } %>
              <% if (p.date_taken) { %><span style="font-size:0.7rem;opacity:0.7">📅 <%= p.date_taken %></span><% } %>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</section>

<!-- 图片查看器 -->
<div id="photoViewer" style="display:none;position:fixed;inset:0;z-index:999;background:rgba(0,0,0,0.92);backdrop-filter:blur(12px);cursor:zoom-out" onclick="this.style.display='none'">
  <img id="viewerImg" style="max-width:90vw;max-height:90vh;position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);object-fit:contain;border-radius:8px">
</div>

<script>
function openViewer(el) {
  const img = el.querySelector('img');
  if (!img) return;
  document.getElementById('viewerImg').src = img.dataset.full || img.src;
  document.getElementById('photoViewer').style.display = 'block';
}
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') document.getElementById('photoViewer').style.display = 'none';
});
</script>

<style>
.photo-grid { column-count: 3; column-gap: 12px; }
.photo-item {
  break-inside: avoid; margin-bottom: 12px; cursor: pointer;
  border-radius: 10px; overflow: hidden; position: relative;
  transition: var(--transition);
}
.photo-item { position: relative; }
.photo-item:hover { transform: scale(1.01); }
.photo-item img, .photo-item video { width: 100%; display: block; border-radius: 10px; }
.photo-play-btn {
  position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%);
  width: 44px; height: 44px; border-radius: 50%;
  background: rgba(0,0,0,0.6); color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.2rem; pointer-events: none;
  border: 2px solid rgba(255,255,255,0.3);
}
.photo-desc {
  position: absolute; bottom: 0; left: 0; right: 0;
  padding: 8px 12px; background: linear-gradient(transparent, rgba(0,0,0,0.6));
  color: #fff; font-size: 0.78rem; opacity: 0; transition: var(--transition);
}
.photo-item:hover .photo-desc { opacity: 1; }
@media (max-width: 768px) { .photo-grid { column-count: 2; column-gap: 8px; } .photo-item { margin-bottom: 8px; } }
</style>

<%- include('partials/footer') %>
