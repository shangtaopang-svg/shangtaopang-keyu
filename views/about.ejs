/* ===== 人生轨迹 · 可视化时间线 ===== */
.vtl { position: relative; max-width: 620px; margin: 0 auto; padding: 10px 0; }
.vtl-track { position: relative; }
.vtl-line {
  position: absolute;
  left: 50%; top: 0; bottom: 0;
  width: 4px;
  background: #000;
  transform: translateX(-50%);
}
.vtl-node {
  position: relative;
  margin-bottom: 20px;
  display: flex;
  align-items: flex-start;
}
.vtl-node.vtl-right { justify-content: flex-end; }
.vtl-node.vtl-start { justify-content: center; }
.vtl-node.vtl-start .vtl-card { text-align: center; }

.vtl-dot {
  position: absolute;
  left: 50%;
  top: 20px;
  width: 18px; height: 18px;
  background: var(--c, #000);
  border: 3px solid #000;
  border-radius: 50%;
  transform: translateX(-50%);
  z-index: 2;
  transition: transform 0.3s, box-shadow 0.3s;
}
.vtl-dot-active {
  width: 22px; height: 22px;
  box-shadow: 0 0 0 4px rgba(211,84,0,0.2);
  animation: vtlPulse 2s ease-in-out infinite;
}
.vtl-dot-birth {
  width: 24px; height: 24px;
  border: 4px solid #000;
}
@keyframes vtlPulse {
  0%, 100% { box-shadow: 0 0 0 4px rgba(211,84,0,0.2); }
  50% { box-shadow: 0 0 0 10px rgba(211,84,0,0.08); }
}

.vtl-card {
  width: 44%;
  background: #fff;
  border: 3px solid #000;
  padding: 14px 16px;
  position: relative;
  transition: transform 0.2s, box-shadow 0.2s;
  margin-left: auto;
  margin-right: auto;
}
.vtl-node:not(.vtl-right):not(.vtl-start) .vtl-card { margin-right: 52%; margin-left: 0; }
.vtl-node.vtl-right .vtl-card { margin-left: 52%; margin-right: 0; }
.vtl-node.vtl-start .vtl-card { margin: 0 auto; width: auto; min-width: 200px; }

.vtl-card:hover {
  transform: translateY(-3px);
  box-shadow: 6px 6px 0 var(--accent, #000);
}
