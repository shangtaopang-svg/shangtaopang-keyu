<section class="ab-section">
  <div class="container">
    <div class="ab-contact">
      <h2 class="ab-section-title" data-zh="📬 聊一聊" data-en="📬 Let's Talk">📬 聊一聊</h2>
      <p data-zh="如果有想法、合作，或者只是想交个朋友——" data-en="If you have ideas, opportunities, or just want to connect —">如果有想法、合作，或者只是想交个朋友——</p>
      <form class="ab-contact-form" id="contactForm">
        <input type="text" class="ab-cf-input" id="cfName" placeholder="你的名字" data-zh-placeholder="你的名字" data-en-placeholder="Your Name" required>
        <input type="email" class="ab-cf-input" id="cfEmail" placeholder="邮箱（选填）" data-zh-placeholder="邮箱（选填）" data-en-placeholder="Email (optional)">
        <textarea class="ab-cf-input ab-cf-area" id="cfMessage" placeholder="想说的话..." data-zh-placeholder="想说的话..." data-en-placeholder="Your message..." required rows="3"></textarea>
        <button type="submit" class="ab-cf-btn" data-zh="发送 💬" data-en="Send 💬">发送 💬</button>
        <div class="ab-cf-status" id="cfStatus"></div>
      </form>
      <div class="ab-footer-tagline" data-zh="种一棵树最好的时间是十年前，其次是现在。" data-en="The best time to plant a tree was 10 years ago. The second best time is now.">种一棵树最好的时间是十年前，其次是现在。</div>
    </div>
  </div>
</section>

<script>
document.getElementById('contactForm')?.addEventListener('submit', async function(e) {
  e.preventDefault();
  var btn = this.querySelector('button');
  var status = document.getElementById('cfStatus');
  btn.disabled = true;
  btn.textContent = '⏳';
  status.textContent = '';
  try {
    var res = await fetch('/api/contact', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({
        name: document.getElementById('cfName').value,
        email: document.getElementById('cfEmail').value,
        message: document.getElementById('cfMessage').value
      })
    });
    var data = await res.json();
    if (data.success) {
      status.textContent = '✅ ' + data.message;
      status.className = 'ab-cf-status ab-cf-ok';
      this.reset();
    } else {
      status.textContent = '❌ ' + (data.error || '发送失败');
      status.className = 'ab-cf-status ab-cf-err';
    }
  } catch(e) {
    status.textContent = '❌ 网络错误';
    status.className = 'ab-cf-status ab-cf-err';
  }
  btn.disabled = false;
  btn.textContent = '发送 💬';
});
</script>

