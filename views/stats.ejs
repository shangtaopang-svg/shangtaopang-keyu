<%- include('partials/header') %>

<!-- Hero -->
<section class="st-hero">
  <div class="st-bg">
    <div class="st-shape st-shape-1"></div>
    <div class="st-shape st-shape-2"></div>
  </div>
  <div class="container st-hero-inner">
    <h1 class="st-title" data-zh="学习统计" data-en="Learning Stats">学习统计</h1>
    <p class="st-sub" data-zh="记录你的每一步成长" data-en="Track every step of your progress">记录你的每一步成长</p>
    <div class="st-meta">
      <span><strong><%= stats.totalVideos %></strong> <span data-zh="视频" data-en="videos">视频</span></span>
      <span class="st-dot">·</span>
      <span><strong><%= stats.totalNotes %></strong> <span data-zh="笔记" data-en="notes">笔记</span></span>
      <span class="st-dot">·</span>
      <span><strong><%= stats.totalViews %></strong> <span data-zh="播放" data-en="views">播放</span></span>
    </div>
  </div>
</section>

<!-- 数据 -->
<section class="section">
  <div class="container">
    <!-- 统计卡片 -->
    <div class="st-grid">
      <div class="st-card" style="--accent:#3b82f6">
        <span class="st-icon">🎬</span>
        <span class="st-num" data-target="<%= stats.totalVideos %>"><%= stats.totalVideos %></span>
        <span class="st-label" data-zh="已收录视频" data-en="Videos">已收录视频</span>
      </div>
      <div class="st-card" style="--accent:#10b981">
        <span class="st-icon">📝</span>
        <span class="st-num" data-target="<%= stats.totalNotes %>"><%= stats.totalNotes %></span>
        <span class="st-label" data-zh="学习笔记" data-en="Notes">学习笔记</span>
      </div>
      <div class="st-card" style="--accent:#8b5cf6">
        <span class="st-icon">👁️</span>
        <span class="st-num" data-target="<%= stats.totalViews %>"><%= stats.totalViews %></span>
        <span class="st-label" data-zh="总播放" data-en="Views">总播放</span>
      </div>
      <div class="st-card" style="--accent:#f59e0b">
        <span class="st-icon">⭐</span>
        <span class="st-num" data-target="<%= stats.totalFavorites %>"><%= stats.totalFavorites %></span>
        <span class="st-label" data-zh="收藏视频" data-en="Favorites">收藏视频</span>
      </div>
      <div class="st-card st-card-streak" style="--accent:#f97316">
        <span class="st-icon">🔥</span>
        <span class="st-num" data-target="<%= stats.streak %>"><%= stats.streak %></span>
        <span class="st-label" data-zh="连续学习天数" data-en="Streak">连续学习天数</span>
        <span class="st-badge" data-zh="持续学习中" data-en="On fire">持续学习中</span>
      </div>
    </div>

    <!-- 打卡 -->
    <div class="st-section">
      <div class="st-section-header">
        <span>📅 <span data-zh="本周打卡" data-en="This Week">本周打卡</span></span>
        <form method="POST" action="/api/checkin" id="checkinForm" style="display:inline">
          <button type="submit" class="st-chk-btn" data-zh="✅ 今日打卡" data-en="✅ Check In">✅ 今日打卡</button>
        </form>
      </div>
      <div class="st-chk-body">
        <div class="week-grid">
          <% weekCheckins.forEach(d => { %>
            <div class="week-day <%= d.checked ? 'checked' : '' %>">
              <span class="wd-date"><%= new Date(d.date).toLocaleDateString('zh-CN', {weekday:'short'}) %></span>
              <span class="wd-icon"><%= d.checked ? '✅' : '○' %></span>
            </div>
          <% }) %>
        </div>
        <div class="st-streak">
          <span class="st-fire">🔥</span>
          <span class="st-fire-num"><%= stats.streak %></span>
          <span class="st-fire-label" data-zh="天连续学习" data-en="day streak">天连续学习</span>
        </div>
      </div>
    </div>

    <!-- 收藏 -->
    <div class="st-section">
      <div class="st-section-header">
        <span>⭐ <span data-zh="收藏的视频" data-en="Favorite Videos">收藏的视频</span></span>
        <span class="st-fav-badge" id="favCountBadge">0</span>
      </div>
      <div id="favoritesList" class="st-fav-list" data-zh="加载中..." data-en="Loading...">加载中...</div>
    </div>
  </div>
</section>

<script>
document.getElementById('checkinForm')?.addEventListener('submit', async function(e) {
  e.preventDefault();
  var btn = this.querySelector('button');
  btn.disabled = true; btn.textContent = '⏳';
  var res = await fetch('/api/checkin', { method: 'POST', headers: {'Content-Type':'application/json'} });
  var data = await res.json();
  if (data.checked) {
    btn.textContent = '✅';
    var toast = document.createElement('div');
    toast.style.cssText = 'position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);background:rgba(0,0,0,0.85);color:#fff;padding:24px 36px;border-radius:16px;text-align:center;z-index:99999;font-size:1.1rem;opacity:0;transition:opacity 0.3s';
    toast.innerHTML = '<div style="font-size:2.5rem;margin-bottom:8px">🎉</div><strong data-zh="打卡成功！" data-en="Checked in!">打卡成功！</strong><br><small data-zh="继续保持！" data-en="Keep going!" style="opacity:0.7">继续保持！</small>';
    document.body.appendChild(toast);
    setTimeout(function(){toast.style.opacity='1'}, 50);
    setTimeout(function(){toast.style.opacity='0';setTimeout(function(){toast.remove();location.reload()},300)}, 2000);
  }
});

fetch('/api/favorites').then(function(r){return r.json()}).then(function(data){
  var ids = data.ids || [];
  var el = document.getElementById('favoritesList');
  var badge = document.getElementById('favCountBadge');
  if (badge) badge.textContent = ids.length;
  if (ids.length === 0) {
    el.innerHTML = '<div class="st-fav-empty">📂 <span data-zh="还没有收藏视频" data-en="No favorite videos yet">还没有收藏视频</span></div>';
    return;
  }
  el.innerHTML = ids.map(function(id, i) {
    return '<a href="/video/' + id + '" class="st-fav-item" style="--d:' + i + 's">' +
      '<span class="st-fav-num">' + (i+1) + '</span>' +
      '<span>⭐ <span data-zh="视频 #' + id + '" data-en="Video #' + id + '">视频 #' + id + '</span></span>' +
      '<span class="st-fav-arrow">→</span></a>';
  }).join('');
});

// 数字动画
(function(){
  var observer = new IntersectionObserver(function(entries){
    entries.forEach(function(entry){
      if (!entry.isIntersecting) return;
      var el = entry.target;
      var target = parseInt(el.getAttribute('data-target'));
      if (isNaN(target) || target === 0) return;
      var start = performance.now(), duration = 1000;
      function update(now) {
        var p = Math.min((now - start) / duration, 1);
        var eased = p === 1 ? 1 : 1 - Math.pow(2, -10 * p);
        el.textContent = Math.round(0 + (target - 0) * eased);
        if (p < 1) requestAnimationFrame(update);
      }
      requestAnimationFrame(update);
      observer.unobserve(el);
    });
  }, {threshold: 0.5});
  document.querySelectorAll('.st-num[data-target]').forEach(function(el){observer.observe(el)});
})();
</script>

<style>
/* ===== Hero ===== */
.st-hero {
  position: relative; padding: 56px 0 40px; overflow: hidden;
  background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #0f172a 100%); color: #fff; text-align: center;
}
.st-bg { position: absolute; inset: 0; pointer-events: none; overflow: hidden; }
.st-shape { position: absolute; border-radius: 50%; opacity: 0.07; }
.st-shape-1 { width: 400px; height: 400px; background: radial-gradient(circle, #60a5fa, transparent); top: -150px; right: -100px; animation: stFloat 8s ease-in-out infinite; }
.st-shape-2 { width: 300px; height: 300px; background: radial-gradient(circle, #fb923c, transparent); bottom: -120px; left: -80px; animation: stFloat 10s ease-in-out infinite reverse; }
@keyframes stFloat { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-20px)} }
.st-hero-inner { position: relative; z-index: 1; }
.st-title {
  font-size: clamp(2rem, 4.5vw, 3rem); font-weight: 900; letter-spacing: -0.02em;
  background: linear-gradient(135deg, #fff, #60a5fa); -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin-bottom: 8px;
}
.st-sub { font-size: clamp(0.9rem, 1.5vw, 1.05rem); color: rgba(255,255,255,0.5); font-weight: 300; margin-bottom: 16px; }
.st-meta { display: inline-flex; align-items: center; gap: 8px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 20px; padding: 6px 18px; font-size: 0.85rem; color: rgba(255,255,255,0.6); }
.st-meta strong { font-weight: 800; color: #60a5fa; font-size: 1.1rem; }
.st-dot { opacity: 0.3; }

/* ===== Cards ===== */
.st-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 12px; margin-bottom: 20px; }
.st-card {
  display: flex; flex-direction: column; align-items: center; gap: 6px; padding: 20px 10px;
  background: var(--bg-card); border: 1px solid var(--border); border-radius: 14px; text-align: center;
  transition: all 0.3s; position: relative; overflow: hidden;
}
.st-card::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
  background: var(--accent); opacity: 0; transition: opacity 0.3s;
}
.st-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.08); border-color: transparent; }
.st-card:hover::before { opacity: 1; }
.st-icon { font-size: 1.6rem; margin-bottom: 2px; }
.st-num { font-size: 1.8rem; font-weight: 800; color: var(--text); line-height: 1; }
.st-label { font-size: 0.72rem; color: var(--text-muted); font-weight: 600; }
.st-badge {
  font-size: 0.6rem; font-weight: 700; padding: 2px 10px; border-radius: 10px;
  background: rgba(249,115,22,0.1); color: #f97316; margin-top: 2px;
}

/* ===== Sections ===== */
.st-section { background: var(--bg-card); border: 1px solid var(--border); border-radius: 14px; padding: 20px; margin-bottom: 16px; }
.st-section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 14px; font-weight: 600; font-size: 0.9rem; }

/* Check-in */
.st-chk-body { display: flex; justify-content: space-between; align-items: center; gap: 20px; }
.week-grid { display: flex; gap: 6px; }
.week-day { display: flex; flex-direction: column; align-items: center; gap: 4px; padding: 8px 12px; border-radius: 8px; background: var(--bg); border: 1px solid var(--border); min-width: 44px; }
.week-day.checked { border-color: rgba(34,197,94,0.3); background: rgba(34,197,94,0.06); }
.wd-date { font-size: 0.7rem; color: var(--text-muted); }
.wd-icon { font-size: 1rem; }
.st-streak { display: flex; align-items: center; gap: 6px; flex-shrink: 0; }
.st-fire { font-size: 1.6rem; }
.st-fire-num { font-size: 1.8rem; font-weight: 900; background: linear-gradient(135deg, #f97316, #ef4444); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
.st-fire-label { font-size: 0.7rem; color: var(--text-muted); }
.st-chk-btn {
  padding: 8px 18px; border: none; border-radius: 8px; font-size: 0.8rem; font-weight: 700; cursor: pointer;
  background: linear-gradient(135deg, #10b981, #059669); color: #fff !important;
  transition: transform 0.2s; font-family: inherit;
}
.st-chk-btn:hover { transform: translateY(-2px); }
.st-chk-btn:disabled { opacity: 0.4; }

/* Favorites */
.st-fav-list { min-height: 40px; }
.st-fav-empty { text-align: center; padding: 24px; color: var(--text-muted); font-size: 0.85rem; }
.st-fav-item {
  display: flex; align-items: center; gap: 10px; padding: 8px 10px; border-radius: 8px;
  text-decoration: none !important; color: var(--text-secondary) !important; font-size: 0.85rem;
  transition: background 0.2s; animation: favIn 0.3s ease both; animation-delay: var(--d, 0s);
}
@keyframes favIn { from { opacity: 0; transform: translateX(-10px); } to { opacity: 1; transform: translateX(0); } }
.st-fav-item:hover { background: rgba(59,130,246,0.04); }
.st-fav-num { width: 24px; height: 24px; border-radius: 50%; background: rgba(59,130,246,0.1); color: var(--primary); display: flex; align-items: center; justify-content: center; font-size: 0.7rem; font-weight: 700; flex-shrink: 0; }
.st-fav-arrow { margin-left: auto; color: var(--text-muted); font-size: 0.8rem; }
.st-fav-badge { font-size: 0.75rem; color: var(--text-muted); font-weight: 600; background: var(--bg); padding: 2px 10px; border-radius: 10px; }

/* ===== Theme ===== */
[data-style="organic"] .st-hero { background: linear-gradient(135deg, #f5f0eb, #ede5d8); }
[data-style="organic"] .st-title { background: linear-gradient(135deg, #3d3229, #7a9e7e); -webkit-background-clip: text; }
[data-style="organic"] .st-meta strong { color: #7a9e7e; }
[data-style="organic"] .st-card { border-color: #e8ddd0; border-radius: 18px; }
[data-style="organic"] .st-card:hover { border-color: #7a9e7e; }
[data-style="organic"] .st-badge { background: rgba(196,113,74,0.1); color: #c4714a; }
[data-style="organic"] .st-chk-btn { background: linear-gradient(135deg, #7a9e7e, #6a8e6e); }
[data-style="organic"] .st-section { border-color: #e8ddd0; border-radius: 18px; }
[data-style="organic"] .st-fire-num { background: linear-gradient(135deg, #c4714a, #7a9e7e); -webkit-background-clip: text; }

[data-style="brutalism"] .st-hero { background: #f5f0e8; border-bottom: 4px solid #000; }
[data-style="brutalism"] .st-title { background: none; -webkit-text-fill-color: #000; text-transform: uppercase; }
[data-style="brutalism"] .st-meta { background: #fff; border: 3px solid #000; color: #000; }
[data-style="brutalism"] .st-meta strong { color: #D35400; }
[data-style="brutalism"] .st-card { border-radius: 0; border-width: 3px; border-color: #000; }
[data-style="brutalism"] .st-card:hover { transform: translateY(-4px); box-shadow: 6px 6px 0 #000; }
[data-style="brutalism"] .st-badge { background: #D35400; color: #fff; border-radius: 0; }
[data-style="brutalism"] .st-chk-btn { border-radius: 0; border: 3px solid #000; background: #fff; color: #000 !important; box-shadow: 3px 3px 0 #000; }
[data-style="brutalism"] .st-section { border-radius: 0; border-width: 3px; border-color: #000; }
[data-style="brutalism"] .week-day { border-radius: 0; }
[data-style="brutalism"] .st-fav-num { border-radius: 0; background: #000; color: #fff; }

[data-style="magazine"] .st-hero { background: linear-gradient(135deg, #faf8f5, #f0ece4); border-bottom: 2px solid #c0392b; }
[data-style="magazine"] .st-title { font-family: Georgia, serif; background: none; -webkit-text-fill-color: #1a1a1a; font-style: italic; }
[data-style="magazine"] .st-card { border-radius: 0; border-color: #e0ddd5; }
[data-style="magazine"] .st-card:hover { border-color: #c0392b; }
[data-style="magazine"] .st-section { border-radius: 0; border-color: #e0ddd5; }
[data-style="magazine"] .st-chk-btn { border-radius: 0; background: #c0392b; }
[data-style="magazine"] .st-fire-num { background: none; -webkit-text-fill-color: #c0392b; color: #c0392b; font-family: Georgia, serif; }
[data-style="magazine"] .st-badge { background: transparent; border: 1px solid #c0392b; color: #c0392b; border-radius: 0; }

/* ===== Responsive ===== */
@media (max-width: 768px) {
  .st-grid { grid-template-columns: repeat(3, 1fr); }
  .st-chk-body { flex-direction: column; align-items: stretch; }
  .st-streak { justify-content: center; padding-top: 12px; border-top: 1px solid var(--border); }
  .week-grid { justify-content: center; }
}
@media (max-width: 480px) {
  .st-grid { grid-template-columns: repeat(2, 1fr); }
}
</style>

<%- include('partials/footer') %>
