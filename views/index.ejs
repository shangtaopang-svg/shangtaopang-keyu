<%- include('partials/header') %>

<!-- 全屏色彩墙背景 -->
<div class="color-wall" id="colorWall"></div>

<!-- Hero -->
<section class="hero-wall">
  <div class="hero-slogan" data-zh="生活本来就是五颜六色的" data-en="Life is Colorful">生活本来就是五颜六色的</div>
  <div class="hero-widget" id="heroWidget">
    <div class="hw-date" id="hwDate">
      <span class="hw-solar" id="hwSolar"></span>
      <span class="hw-lunar" id="hwLunar"><%= typeof lunarStr !== 'undefined' ? lunarStr : '' %></span>
    </div>
    <div class="hw-weather" id="hwWeather">
      <span class="hw-icon" id="hwIcon">☀️</span>
      <span class="hw-temp" id="hwTemp">28°C</span>
      <span class="hw-desc" id="hwDesc">晴</span>
    </div>
  </div>
  <div class="hero-overlay">
    <div class="hero-content">
      <div class="hero-badge" data-zh="25年房地产 · 10年工业地产 · AI学习者" data-en="25y Real Estate · 10y Industrial · AI Learner">25年房地产 · 10年工业地产 · AI学习者</div>
      <h1 class="hero-title">
        <span data-zh="庞尚韬" data-en="Shangtao Pang">庞尚韬</span>
        <span class="hero-sub" data-zh="用AI学习 · 用代码创造" data-en="Learn with AI · Create with Code">用AI学习 · 用代码创造</span>
      </h1>
      <div class="hero-divider"></div>
      <div class="hero-actions">
        <a href="/about" class="hero-btn hero-btn-primary" data-zh="关于我" data-en="About Me">关于我</a>
        <a href="/works" class="hero-btn" data-zh="我的作品" data-en="My Works">我的作品</a>
        <a href="/categories" class="hero-btn" data-zh="AI学习" data-en="AI Learning">AI学习</a>
      </div>
      <div class="hero-stats">
        <div class="hs-item"><span class="hs-num"><%= stats?.totalVideos || 0 %></span><span class="hs-label" data-zh="视频" data-en="Videos">视频</span></div>
        <div class="hs-item"><span class="hs-num"><%= stats?.totalNotes || 0 %></span><span class="hs-label" data-zh="笔记" data-en="Notes">笔记</span></div>
        <div class="hs-item"><span class="hs-num"><%= stats?.streak || 0 %></span><span class="hs-label" data-zh="学习" data-en="Days">学习</span></div>
        <div class="hs-item"><span class="hs-num"><%= (typeof works !== 'undefined' ? works.length : 0) %></span><span class="hs-label" data-zh="作品" data-en="Works">作品</span></div>
      </div>

      <!-- 生日倒计时 -->
      <div class="hero-birthday" id="heroBirthday" data-ts="<%= typeof birthday !== 'undefined' ? birthday.timestamp : 0 %>">
        <span class="hb-icon">🎂</span>
        <span class="hb-text" id="hbText">
          <% if (typeof birthday !== 'undefined' && birthday.isToday) { %>
            <span data-zh="🎉 生日快乐！" data-en="🎉 Happy Birthday!">🎉 生日快乐！</span>
          <% } else { %>
            <span data-zh="距离生日还有" data-en="Birthday in">距离生日还有</span>
            <strong class="hb-count" id="hbDays"><%= typeof birthday !== 'undefined' ? birthday.daysUntil : '--' %></strong>
            <span data-zh="天" data-en="d">天</span>
            <strong class="hb-count hb-count-sm" id="hbHours">00</strong><span class="hb-unit" data-zh="时" data-en="h">时</span>
            <strong class="hb-count hb-count-sm" id="hbMins">00</strong><span class="hb-unit" data-zh="分" data-en="m">分</span>
            <strong class="hb-count hb-count-sm" id="hbSecs">00</strong><span class="hb-unit" data-zh="秒" data-en="s">秒</span>
            <span class="hb-date" data-zh="（农历六月初七 · <%= typeof birthday !== 'undefined' ? birthday.month + '/' + birthday.day : '' %>）" data-en="(Lunar 6/7 · <%= typeof birthday !== 'undefined' ? birthday.month + '/' + birthday.day : '' %>)">（农历六月初七 · <%= typeof birthday !== 'undefined' ? birthday.month + '/' + birthday.day : '' %>）</span>
          <% } %>
        </span>
      </div>
    </div>
  </div>
</section>

<!-- Dashboard -->
<section class="dash-section">
  <div class="dash-inner">
    <!-- 导航 -->
    <nav class="dash-nav">
      <a href="/" class="dash-logo">PST</a>
      <a href="/stats" class="dash-link active" data-zh="概览" data-en="Overview">概览</a>
      <a href="/works" class="dash-link" data-zh="作品" data-en="Works">作品</a>
      <a href="/study" class="dash-link" data-zh="笔记" data-en="Notes">笔记</a>
      <a href="/about" class="dash-link" data-zh="关于" data-en="About">关于</a>
      <span class="dash-spacer"></span>
      <span class="dash-theme" id="dashTheme">🌙</span>
    </nav>

    <!-- 统计卡片 -->
    <div class="dash-cards">
      <div class="dash-card">
        <div class="dc-value"><%= stats?.totalVideos || 0 %></div>
        <div class="dc-label" data-zh="视频" data-en="Videos">视频</div>
      </div>
      <div class="dash-card">
        <div class="dc-value"><%= stats?.totalNotes || 0 %></div>
        <div class="dc-label" data-zh="笔记" data-en="Notes">笔记</div>
      </div>
      <div class="dash-card">
        <div class="dc-value"><%= stats?.streak || 0 %></div>
        <div class="dc-label" data-zh="学习" data-en="Days">学习</div>
      </div>
      <div class="dash-card">
        <div class="dc-value"><%= (typeof works !== 'undefined' ? works.length : 0) %></div>
        <div class="dc-label" data-zh="作品" data-en="Works">作品</div>
      </div>
    </div>

    <!-- 图表 + 动态 -->
    <div class="dash-panels">
      <div class="dash-chart-wrap">
        <div class="dash-panel-title" data-zh="学习统计" data-en="Learning Stats">学习统计</div>
        <div class="dash-bars">
          <% const bv = [Number(stats?.totalVideos||0), Number(stats?.totalNotes||0), Number(stats?.streak||0), Number(typeof works !== 'undefined' ? works.length : 0)]; %>
          <% const mv = Math.max(...bv, 1); %>
          <% const vl = ['视频','笔记','打卡','作品']; %>
          <% const vel = ['Videos','Notes','Check-in','Works']; %>
          <% bv.forEach(function(v, i) { %><div class="db-col"><div class="db-bar-wrap"><div class="db-bar" style="height:<%= Math.max(v/mv*80, v>0?4:0) %>%"></div></div><div class="db-val"><%= v %></div><div class="db-label" data-zh="<%= vl[i] %>" data-en="<%= vel[i] %>"><%= vl[i] %></div></div><% }) %>
        </div>
      </div>
      <div class="dash-log-wrap">
        <div class="dash-panel-title" data-zh="动态" data-en="Activity">动态</div>
        <div class="dash-log-item"><span class="dl-dot"></span><span data-zh="收录 <%= stats?.totalVideos || 0 %> 个视频" data-en="<%= stats?.totalVideos || 0 %> videos collected">收录 <%= stats?.totalVideos || 0 %> 个视频</span></div>
        <div class="dash-log-item"><span class="dl-dot"></span><span data-zh="<%= stats?.totalNotes || 0 %> 篇笔记" data-en="<%= stats?.totalNotes || 0 %> notes"><%= stats?.totalNotes || 0 %> 篇笔记</span></div>
        <div class="dash-log-item"><span class="dl-dot"></span><span data-zh="<%= (typeof works !== 'undefined' ? works.length : 0) %> 个作品" data-en="<%= (typeof works !== 'undefined' ? works.length : 0) %> works"><%= (typeof works !== 'undefined' ? works.length : 0) %> 个作品</span></div>
      </div>
    </div>

    <!-- 底部配置 -->
    <div class="dash-footer">
      <span class="df-item"><span data-zh="主题" data-en="Theme">主题</span> <span id="dashThemeIcon" style="cursor:pointer">🌙</span></span>
      <span class="df-item"><span data-zh="语言" data-en="Language">语言</span> <span id="dashLang" style="cursor:pointer">CN</span></span>
      <span class="df-item"><span data-zh="通知" data-en="Notifications">通知</span> <span id="dashNotif" style="cursor:pointer">🔔</span></span>
      <span class="df-item df-date" data-zh="最近更新" data-en="Last Updated">最近更新</span>
    </div>
  </div>
</section>

<style>
/* ===== 色彩墙 · 生活五颜六色 ===== */

.hero-wall {
  position: relative;
  width: 100%;
  height: 100vh;
  overflow: hidden;
  z-index: 1;
  background: transparent;
}

/* 色板卡风格 — 双色背景（JS 驱动变色） */
@property --cw-c1 { syntax: '<color>'; initial-value: #D35400; inherits: false; }
@property --cw-c2 { syntax: '<color>'; initial-value: #0D9488; inherits: false; }
.color-wall {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  z-index: 0;
  background: linear-gradient(180deg, var(--cw-c1, #D35400) 0%, var(--cw-c1, #D35400) 30%, var(--cw-c2, #0D9488) 30%, var(--cw-c2, #0D9488) 100%);
  transition: --cw-c1 1s ease, --cw-c2 1s ease;
}

[data-style="color-wall"] .hero-wall::after { display: none; }
[data-style="color-wall"] .hero-overlay {
  top: 62%;
  bottom: auto;
  left: 50%;
  transform: translate(-50%, -50%);
  padding-bottom: 0;
  align-items: center;
}
[data-style="color-wall"] .hero-slogan {
  top: 15%;
  transform: translate(-50%, -50%);
}



/* 口号 — 黑底白字面板 */
.hero-slogan {
  position: absolute;
  top: 18%; left: 50%;
  transform: translate(-50%, -50%);
  z-index: 10;
  font-size: clamp(1.4rem, 3.5vw, 2.6rem);
  font-weight: 900;
  color: #fff;
  text-align: center;
  line-height: 1.3;
  letter-spacing: 0.1em;
  pointer-events: none;
  width: auto;
  max-width: 90%;
  background: #141416;
  padding: 16px 36px;
  border-radius: 10px;
  box-shadow: 0 4px 20px rgba(0,0,0,0.2), 0 8px 40px rgba(0,0,0,0.1);
  white-space: nowrap;
}

@media (max-width: 768px) {
  .hero-slogan { white-space: normal; padding: 12px 20px; font-size: clamp(1rem, 3.5vw, 1.4rem); top: 12%; }
  .color-tile { width: 36px; height: 48px; }
  .hero-widget { padding: 10px 14px; min-width: 140px; }
  .hw-solar { font-size: 0.8rem; }
  .hw-icon { font-size: 1.3rem; }
}

/* 日历/天气卡片 */
.hero-widget {
  position: absolute;
  top: 4%; right: 4%;
  z-index: 10;
  background: rgba(0,0,0,0.35);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 12px;
  padding: 12px 20px;
  min-width: 170px;
  pointer-events: none;
}

.hw-date {
  display: flex;
  flex-direction: column;
  gap: 2px;
  margin-bottom: 6px;
  padding-bottom: 6px;
  border-bottom: 1px solid rgba(255,255,255,0.06);
}

.hw-solar {
  font-size: 0.9rem;
  font-weight: 700;
  color: #fff;
}

.hw-lunar {
  font-size: 0.7rem;
  color: rgba(255,255,255,0.45);
}

.hw-weather {
  display: flex;
  align-items: center;
  gap: 6px;
}

.hw-icon {
  font-size: 1.5rem;
  line-height: 1;
}

.hw-temp {
  font-size: 1rem;
  font-weight: 700;
  color: #fff;
}

.hw-desc {
  font-size: 0.7rem;
  color: rgba(255,255,255,0.45);
}

/* 渐变遮罩（浅底，底部渐变到深色） */
.hero-wall::after {
  content: '';
  position: absolute;
  inset: 0;
  z-index: 1;
  background: linear-gradient(180deg,
    transparent 0%,
    transparent 50%,
    rgba(0,0,0,0.06) 75%,
    rgba(0,0,0,0.25) 90%,
    rgba(0,0,0,0.50) 100%
  );
  pointer-events: none;
}

/* 场景层（底部内容） */
.hero-overlay {
  position: absolute;
  bottom: 0; left: 0;
  width: 100%;
  z-index: 3;
  display: flex;
  justify-content: center;
  align-items: flex-end;
  pointer-events: none;
  padding-bottom: 30px;
}


/* 纯色内容卡（不透彩色） */
.hero-content {
  text-align: center;
  max-width: 680px;
  width: 90%;
  padding: 22px 28px 18px;
  pointer-events: auto;
  background: #141416;
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 16px;
  transform: translateZ(30px) rotateX(0deg) rotateY(0deg);
  transition: transform 0.15s ease-out;
  box-shadow:
    0 -10px 40px rgba(0,0,0,0.3),
    0 10px 60px rgba(0,0,0,0.4),
    inset 0 1px 0 rgba(255,255,255,0.04);
}

.hero-badge {
  display: inline-block;
  font-size: 0.7rem;
  font-weight: 600;
  color: rgba(255,255,255,0.6);
  letter-spacing: 0.12em;
  text-transform: uppercase;
  margin-bottom: 16px;
  padding: 4px 14px;
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 20px;
  background: rgba(255,255,255,0.03);
}

.hero-title {
  font-size: clamp(2.5rem, 6vw, 3.8rem);
  font-weight: 900;
  line-height: 0.9;
  color: #fff;
  letter-spacing: -0.02em;
  margin: 0 0 4px;
  text-shadow: 0 2px 20px rgba(0,0,0,0.3);
}

.hero-sub {
  display: block;
  font-size: clamp(0.9rem, 1.5vw, 1.05rem);
  font-weight: 300;
  color: rgba(255,255,255,0.7);
  letter-spacing: 0.08em;
  margin-top: 10px;
  text-transform: uppercase;
}

.hero-divider {
  width: 30px;
  height: 2px;
  background: rgba(255,255,255,0.3);
  margin: 12px auto;
}

.hero-desc {
  font-size: 0.78rem;
  color: rgba(255,255,255,0.5);
  letter-spacing: 0.05em;
  margin-bottom: 28px;
  text-transform: uppercase;
}

.hero-actions {
  display: flex;
  gap: 6px;
  justify-content: center;
  flex-wrap: wrap;
  margin-bottom: 20px;
}

.hero-btn {
  padding: 10px 28px;
  font-size: 0.72rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  text-decoration: none !important;
  color: rgba(255,255,255,0.7) !important;
  border: 1px solid rgba(255,255,255,0.15);
  border-radius: 8px;
  transition: all 0.25s ease;
  background: rgba(255,255,255,0.03);
}

.hero-btn:hover {
  border-color: rgba(255,255,255,0.4);
  color: #fff !important;
  background: rgba(255,255,255,0.08);
  transform: translateY(-2px);
}

.hero-btn-primary {
  background: rgba(59,130,246,0.25);
  border-color: rgba(59,130,246,0.3);
  color: #fff !important;
}

.hero-btn-primary:hover {
  background: rgba(59,130,246,0.4);
  border-color: rgba(59,130,246,0.5);
}

/* 统计 */
.hero-stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0;
  border-top: 1px solid rgba(255,255,255,0.08);
  border-bottom: 1px solid rgba(255,255,255,0.08);
}

.hs-item {
  padding: 8px 8px;
  text-align: center;
  border-right: 1px solid rgba(255,255,255,0.08);
}

.hs-item:last-child { border-right: none; }

.hs-num {
  display: block;
  font-size: 1.3rem;
  font-weight: 800;
  color: #fff;
  line-height: 1;
  margin-bottom: 4px;
  text-shadow: 0 0 20px rgba(59,130,246,0.3);
}

.hs-label {
  font-size: 0.55rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: rgba(255,255,255,0.4);
}

/* 生日倒计时 */
.hero-birthday {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  margin-top: 12px;
  padding: 8px 16px;
  background: rgba(251,146,60,0.12);
  border: 1px solid rgba(251,146,60,0.2);
  border-radius: 20px;
  font-size: 0.72rem;
  color: rgba(255,255,255,0.8);
  letter-spacing: 0.04em;
  backdrop-filter: blur(4px);
}
.hb-icon { font-size: 1rem; line-height: 1; }
.hb-text { display: flex; align-items: center; gap: 4px; flex-wrap: wrap; justify-content: center; }
.hb-count {
  font-size: 1rem;
  font-weight: 800;
  color: #fb923c;
  line-height: 1;
  text-shadow: 0 0 12px rgba(251,146,60,0.3);
}
.hb-count-sm {
  font-size: 0.85rem;
  min-width: 18px;
  text-align: center;
}
.hb-unit {
  font-size: 0.6rem;
  color: rgba(255,255,255,0.45);
  margin-right: 4px;
}
.hb-date {
  font-size: 0.6rem;
  color: rgba(255,255,255,0.35);
  margin-left: 2px;
}

/* ===== Dashboard ===== */
.dash-section {
  padding: 40px 24px 60px;
  display: flex;
  justify-content: center;
  background: #ffffff;
  position: relative;
  z-index: 3;
  --text: #1a1a1a;
  --text-muted: #999999;
  --text-secondary: #666666;
  --border: #e0e0e0;
  --primary: #2563eb;
  --bg-card: #ffffff;
}

.dash-inner {
  width: 100%;
  max-width: 960px;
}

/* 导航条 */
.dash-nav {
  display: flex;
  align-items: center;
  gap: 4px;
  padding-bottom: 20px;
  margin-bottom: 24px;
  border-bottom: 1px solid var(--border);
}

.dash-logo {
  font-size: 1rem;
  font-weight: 900;
  color: var(--primary) !important;
  text-decoration: none !important;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-right: 20px;
}

.dash-link {
  padding: 6px 14px;
  font-size: 0.75rem;
  font-weight: 700;
  color: var(--text-muted) !important;
  text-decoration: none !important;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  border: 1px solid transparent;
  transition: all 0.15s;
}

.dash-link:hover { color: var(--text) !important; }
.dash-link.active { color: var(--primary) !important; border-color: var(--primary); }

.dash-spacer { flex: 1; }

.dash-theme {
  font-size: 1rem;
  cursor: pointer;
  padding: 4px 8px;
}

/* 统计卡片 */
.dash-cards {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12px;
  margin-bottom: 24px;
}

.dash-card {
  padding: 20px 16px;
  text-align: center;
  border: 1px solid var(--border);
  transition: border-color 0.2s;
}

.dash-card:hover { border-color: var(--primary); }

.dc-value {
  font-size: 1.6rem;
  font-weight: 900;
  color: var(--text);
  line-height: 1;
  margin-bottom: 6px;
}

.dc-label {
  font-size: 0.6rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--text-muted);
}

/* 图表 + 动态 双栏 */
.dash-panels {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  margin-bottom: 20px;
}

.dash-chart-wrap, .dash-log-wrap {
  border: 1px solid var(--border);
  padding: 20px;
}

.dash-panel-title {
  font-size: 0.6rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--text-muted);
  margin-bottom: 16px;
}

/* 图表条 */
.dash-bars {
  display: flex;
  gap: 4px;
  align-items: flex-end;
  height: 120px;
}

.db-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  height: 100%;
  gap: 4px;
}

.db-bar-wrap {
  width: 100%;
  display: flex;
  justify-content: center;
  align-items: flex-end;
  flex: 1;
}

.db-bar {
  width: 55%;
  background: var(--primary);
  min-height: 2px;
  border-radius: 1px;
  transition: height 0.3s;
}

.db-val {
  font-size: 0.8rem;
  font-weight: 800;
  color: var(--text);
  line-height: 1;
}

.db-label {
  font-size: 0.5rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--text-muted);
}

/* 动态列表 */
.dash-log-item {
  font-size: 0.78rem;
  font-weight: 600;
  padding: 8px 0;
  display: flex;
  align-items: center;
  gap: 10px;
  color: var(--text) !important;
  text-decoration: none !important;
  border-bottom: 1px solid var(--border);
}

.dash-log-item:last-child { border-bottom: none; }

.dl-dot {
  width: 5px;
  height: 5px;
  background: var(--primary);
  flex-shrink: 0;
}

/* 底部配置 */
.dash-footer {
  display: flex;
  gap: 20px;
  padding-top: 16px;
  border-top: 1px solid var(--border);
  flex-wrap: wrap;
}

.df-item {
  font-size: 0.7rem;
  font-weight: 600;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.df-item span { cursor: pointer; color: var(--text); }
.df-item span:hover { color: var(--primary); }
.df-date { margin-left: auto; color: var(--text-muted); }

/* 入场动画 */
@keyframes heroFadeIn {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

.hero-content > * { animation: heroFadeIn 0.6s ease both; }
.hero-content > *:nth-child(1) { animation-delay: 0.1s; }
.hero-content > *:nth-child(2) { animation-delay: 0.2s; }
.hero-content > *:nth-child(3) { animation-delay: 0.3s; }
.hero-content > *:nth-child(4) { animation-delay: 0.4s; }
.hero-content > *:nth-child(5) { animation-delay: 0.5s; }
.hero-content > *:nth-child(6) { animation-delay: 0.6s; }

/* 响应式 */
@media (max-width: 768px) {
  .hero-content { padding: 32px 20px; margin: 0 16px; border-radius: 14px; }
  [data-style="color-wall"] .hero-overlay { top: 55%; width: 96%; }
  .hero-stats { grid-template-columns: repeat(2, 1fr); }
  .hs-item:nth-child(2) { border-right: none; }
  .hs-item:nth-child(3),
  .hs-item:nth-child(4) { border-top: 1px solid rgba(255,255,255,0.08); }
  .dash-cards { grid-template-columns: repeat(2, 1fr); }
  .dash-panels { grid-template-columns: 1fr; }
  .dash-nav { flex-wrap: wrap; }
  .dash-link { font-size: 0.7rem; padding: 4px 10px; }
  .df-date { margin-left: 0; width: 100%; text-align: right; }
}

