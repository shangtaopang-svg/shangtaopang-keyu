<script>
  // 双色背景由 CSS 控制，无需 JS 生成

// Dashboard 交互
document.getElementById('dashTheme')?.addEventListener('click', function() { document.querySelector('.theme-toggle')?.click(); setTimeout(() => this.textContent = document.body.classList.contains('light-theme') ? '☀️' : '🌙', 50); });
document.getElementById('dashThemeIcon')?.addEventListener('click', function() { document.querySelector('.theme-toggle')?.click(); setTimeout(() => this.textContent = document.body.classList.contains('light-theme') ? '☀️' : '🌙', 50); });
document.getElementById('dashLang')?.addEventListener('click', function() { if (typeof toggleLang === 'function') toggleLang(); this.textContent = document.documentElement.lang === 'zh-CN' ? 'CN' : 'EN'; });
document.getElementById('dashNotif')?.addEventListener('click', function() { this.textContent = this.textContent === '🔔' ? '🔕' : '🔔'; });

// === 日历天气（农历由服务端提供） ===
(function() {
  var now = new Date();
  var y = now.getFullYear(), m = now.getMonth() + 1, d = now.getDate();
  var solarEl = document.getElementById('hwSolar');
  if (solarEl) solarEl.textContent = y + '年' + m + '月' + d + '日';

  var iconEl = document.getElementById('hwIcon');
  var tempEl = document.getElementById('hwTemp');
  var descEl = document.getElementById('hwDesc');
  fetch('/api/weather')
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (iconEl) iconEl.textContent = data.icon || '☀️';
      if (tempEl) tempEl.textContent = data.temp || '--°C';
      if (descEl) descEl.textContent = data.desc || '--';
    })
    .catch(function() {
      if (iconEl) iconEl.textContent = '☀️';
      if (tempEl) tempEl.textContent = '--°C';
      if (descEl) descEl.textContent = '--';
    });
})();

// === 生日实时倒计时 ===
(function() {
  var el = document.getElementById('heroBirthday');
  if (!el) return;
  var ts = parseInt(el.getAttribute('data-ts'));
  if (!ts) return;

  function tick() {
    var now = Date.now();
    var diff = ts - now;
    if (diff <= 0) {
      document.getElementById('hbText').innerHTML = '<span data-zh="🎉 生日快乐！" data-en="🎉 Happy Birthday!">🎉 生日快乐！</span>';
      return;
    }
    var days = Math.floor(diff / 86400000);
    var hours = Math.floor((diff % 86400000) / 3600000);
    var mins = Math.floor((diff % 3600000) / 60000);
    var secs = Math.floor((diff % 60000) / 1000);

    var dEl = document.getElementById('hbDays');
    var hEl = document.getElementById('hbHours');
    var mEl = document.getElementById('hbMins');
    var sEl = document.getElementById('hbSecs');
    if (dEl) dEl.textContent = days;
    if (hEl) hEl.textContent = hours.toString().padStart(2, '0');
    if (mEl) mEl.textContent = mins.toString().padStart(2, '0');
    if (sEl) sEl.textContent = secs.toString().padStart(2, '0');
  }
  tick();
  setInterval(tick, 1000);
})();

// === 色板卡背景自动变色 ===
(function() {
  var cw = document.getElementById('colorWall');
  if (!cw) return;
  // 只有在默认色板卡风格下才启用
  var currentStyle = localStorage.getItem('pst-style') || 'color-wall';
  var colors = [
    { c1: '#D35400', c2: '#0D9488' },  // 橘黄 + 青绿
    { c1: '#c0392b', c2: '#2c3e50' },  // 朱红 + 深蓝
    { c1: '#8e44ad', c2: '#f39c12' },  // 紫 + 金
    { c1: '#2980b9', c2: '#e74c3c' },  // 蓝 + 红
    { c1: '#27ae60', c2: '#e67e22' },  // 绿 + 橙
    { c1: '#e91e63', c2: '#00bcd4' },  // 粉 + 青
    { c1: '#1a5276', c2: '#d4ac0d' },  // 深蓝 + 芥黄
    { c1: '#795548', c2: '#607d8b' },  // 棕 + 灰蓝
  ];
  var idx = 0;
  function shiftColor() {
    // 检测当前风格
    var s = document.body.getAttribute('data-style') || localStorage.getItem('pst-style') || 'color-wall';
    if (s !== 'color-wall') return; // 非色板卡风格不动
    idx = (idx + 1) % colors.length;
    var pair = colors[idx];
    cw.style.setProperty('--cw-c1', pair.c1);
    cw.style.setProperty('--cw-c2', pair.c2);
  }
  // 初始设置（确保 CSS 变量存在）
  cw.style.setProperty('--cw-c1', colors[0].c1);
  cw.style.setProperty('--cw-c2', colors[0].c2);
  setInterval(shiftColor, 3000);
})();

</script>
