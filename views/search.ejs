<%- include('partials/header') %>

<section class="page-header">
  <div class="container">
    <h1 class="page-title">🔍 <span data-zh="搜索结果" data-en="Search Results">搜索结果</span></h1>
    <p class="page-desc"><span data-zh="关于 " data-en="Search results for ">关于 </span><span data-zh='"' data-en='"'>"</span><strong><%= query %></strong><span data-zh='" 的搜索结果' data-en='"'>" 的搜索结果</span></p>
  </div>
</section>

<section class="section">
  <div class="container">
    <% if (videos.length === 0) { %>
      <div class="empty-state">
        <span class="empty-icon">🔍</span>
        <h3 data-zh="未找到相关视频" data-en="No related videos found">未找到相关视频</h3>
        <p><span data-zh="没有找到包含 " data-en='No videos found containing "'>没有找到包含 "</span><%= query %><span data-zh='" 的视频，试试其他关键词' data-en='", try other keywords'>" 的视频，试试其他关键词</span></p>
        <a href="/" class="btn btn-primary" data-zh="返回首页" data-en="Back to Home">返回首页</a>
      </div>
    <% } else { %>
      <div class="result-count"><span data-zh="共找到 " data-en="Found ">共找到 </span><%= videos.length %><span data-zh=" 个结果" data-en=" results"> 个结果</span></div>
      <div class="video-grid">
        <% videos.forEach(v => { %>
          <a href="/video/<%= v.id %>" class="video-card">
            <div class="video-thumb">
              <% if (v.thumbnail) { %>
                <img src="<%= v.thumbnail %>" alt="<%= v.title %>" loading="lazy" referrerpolicy="no-referrer">
              <% } else { %>
                <div class="video-thumb-placeholder" style="display:flex;align-items:center;justify-content:center;flex-direction:column;gap:4px;background:linear-gradient(135deg,#6366f1,#4f46e5)"><span style="font-size:2rem">🎬</span><span style="font-size:0.65rem;color:rgba(255,255,255,0.7);background:rgba(0,0,0,0.2);padding:1px 8px;border-radius:6px"><%= v.platform || '视频' %></span></div>
              <% } %>
              <% if (v.duration) { %><span class="video-duration"><%= v.duration %></span><% } %>
            </div>
            <div class="video-info">
              <h3 class="video-title"><%= v.title %></h3>
              <div class="video-meta">
                <span class="video-category"><%= v.category_icon || '📂' %> <%= v.category_name || '未分类' %></span>
                <% if (v.model_name) { %>
                  <span class="video-model"><%= v.model_icon || '🤖' %> <%= v.model_name %></span>
                <% } %>
              </div>
            </div>
          </a>
        <% }) %>
      </div>
    <% } %>
  </div>
</section>

<%- include('partials/footer') %>
