<%- include('../partials/admin-header') %>

<div class="admin-toolbar">
  <h2 class="admin-page-title">📸 <span data-zh="相册管理" data-en="Album Management">相册管理</span></h2>
  <button class="btn btn-primary" onclick="showAlbumForm()" data-zh="＋ 新建相册" data-en="＋ New Album">＋ 新建相册</button>
</div>

<div class="admin-card">
  <div class="table-responsive">
    <table class="admin-table">
      <thead>
        <tr><th data-zh="封面" data-en="Cover">封面</th><th data-zh="名称" data-en="Name">名称</th><th data-zh="年份" data-en="Year">年份</th><th data-zh="照片数" data-en="Photos">照片数</th><th data-zh="操作" data-en="Actions">操作</th></tr>
      </thead>
      <tbody>
        <% if (albums.length === 0) { %>
          <tr><td colspan="5" class="text-center" data-zh="暂无相册" data-en="No albums yet">暂无相册</td></tr>
        <% } else { %>
          <% albums.forEach(a => { %>
            <tr>
              <td>
                <% const coverFile = covers && covers[a.id]; %>
                <% if (coverFile) { %>
                  <img src="<%= coverFile %>" style="width:50px;height:38px;object-fit:cover;border-radius:4px">
                <% } else { %>
                  <span style="font-size:1.4rem">📸</span>
                <% } %>
              </td>
              <td><strong><%= a.title %></strong><br><small style="color:var(--text-muted)"><%= a.description || '' %></small></td>
              <td><%= a.year || '-' %></td>
              <td><%= a.photo_count || 0 %></td>
              <td class="td-actions">
                <a href="/admin/albums/<%= a.id %>" class="btn btn-sm btn-edit" data-zh="管理照片" data-en="Manage Photos">管理照片</a>
                <a href="/gallery/<%= a.id %>" class="btn btn-sm btn-outline" target="_blank" data-zh="预览" data-en="Preview">预览</a>
                <button class="btn btn-sm btn-outline" onclick="uploadPhotos(<%= a.id %>)" data-zh="上传" data-en="Upload">上传</button>
                <form method="POST" action="/admin/albums/delete/<%= a.id %>" style="display:inline" onsubmit="return confirm('删除相册会同时删除所有照片，确认？')">
                  <button type="submit" class="btn btn-sm btn-danger" data-zh="删除" data-en="Delete">删除</button>
                </form>
              </td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<!-- 新建相册弹窗 -->
<div class="modal-overlay" id="albumModal" style="display:none">
  <div class="modal">
    <div class="modal-header">
      <h3 data-zh="新建相册" data-en="New Album">新建相册</h3>
      <button class="modal-close" onclick="closeModal()">×</button>
    </div>
    <form method="POST" action="/admin/albums/save" class="admin-form">
      <input type="hidden" name="id" id="album_id">
      <div class="form-group">
        <label data-zh="相册名称" data-en="Album Name">相册名称</label>
        <input type="text" name="title" id="album_title" class="form-input" required>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label data-zh="年份" data-en="Year">年份</label>
          <input type="text" name="year" id="album_year" class="form-input" placeholder="如: 2026">
        </div>
        <div class="form-group">
          <label data-zh="排序" data-en="Order">排序</label>
          <input type="number" name="sort_order" id="album_sort" class="form-input" value="0">
        </div>
      </div>
      <div class="form-group">
        <label data-zh="描述" data-en="Description">描述</label>
        <input type="text" name="description" id="album_desc" class="form-input">
      </div>
      <div class="form-actions">
        <button type="button" class="btn btn-outline" onclick="closeModal()" data-zh="取消" data-en="Cancel">取消</button>
        <button type="submit" class="btn btn-primary">💾 <span data-zh="保存" data-en="Save">保存</span></button>
      </div>
    </form>
  </div>
</div>

<!-- 上传照片弹窗 -->
<div class="modal-overlay" id="uploadModal" style="display:none">
  <div class="modal">
    <div class="modal-header">
      <h3 data-zh="上传照片" data-en="Upload Photos">上传照片</h3>
      <button class="modal-close" onclick="document.getElementById('uploadModal').style.display='none'">×</button>
    </div>
    <form method="POST" action="" id="uploadForm" enctype="multipart/form-data" class="admin-form">
      <div class="form-group">
        <label data-zh="选择照片（可多选）" data-en="Select Photos (multiple)">选择照片（可多选）</label>
        <input type="file" name="photos" multiple accept="image/*" class="form-input" required>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label data-zh="拍摄日期" data-en="Date Taken">拍摄日期</label>
          <input type="date" name="date_taken" id="uploadDate" class="form-input">
        </div>
        <div class="form-group">
          <label data-zh="备注/描述" data-en="Notes/Description">备注/描述</label>
          <input type="text" name="photo_desc" id="uploadDesc" class="form-input" placeholder="如：2026年春节聚餐" data-zh-placeholder="如：2026年春节聚餐" data-en-placeholder="e.g., 2026 Spring Festival dinner">
        </div>
      </div>
      <div class="form-actions">
        <button type="button" class="btn btn-outline" onclick="document.getElementById('uploadModal').style.display='none'" data-zh="取消" data-en="Cancel">取消</button>
        <button type="submit" class="btn btn-primary">📤 <span data-zh="上传" data-en="Upload">上传</span></button>
      </div>
    </form>
  </div>
</div>

<script>
function showAlbumForm() {
  ['album_id','album_title','album_year','album_desc','album_sort'].forEach(id => document.getElementById(id).value = '');
  document.getElementById('albumModal').style.display = 'flex';
}
function uploadPhotos(albumId) {
  document.getElementById('uploadForm').action = '/admin/albums/upload/' + albumId;
  document.getElementById('uploadModal').style.display = 'flex';
}
function closeModal() { document.getElementById('albumModal').style.display = 'none'; }
</script>

<%- include('../partials/admin-footer') %>
