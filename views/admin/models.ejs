<%- include('../partials/admin-header') %>

<div class="admin-toolbar">
  <h2 class="admin-page-title">🤖 <span data-zh="AI模型管理" data-en="AI Model Management">AI模型管理</span></h2>
  <button class="btn btn-primary" onclick="showAddForm()" data-zh="＋ 添加模型" data-en="＋ Add Model">＋ 添加模型</button>
</div>

<div class="admin-card">
  <div class="table-responsive">
    <table class="admin-table">
      <thead>
        <tr><th data-zh="排序" data-en="Order">排序</th><th data-zh="图标" data-en="Icon">图标</th><th data-zh="名称" data-en="Name">名称</th><th data-zh="公司" data-en="Company">公司</th><th data-zh="标识" data-en="Slug">标识</th><th data-zh="视频数" data-en="Videos">视频数</th><th data-zh="操作" data-en="Actions">操作</th></tr>
      </thead>
      <tbody>
        <% models.forEach(m => { %>
          <tr>
            <td><%= m.sort_order %></td>
            <td><span style="font-size:1.5rem"><%= m.icon %></span></td>
            <td><%= m.name %></td>
            <td><%= m.company || '-' %></td>
            <td><code><%= m.slug %></code></td>
            <td><%= m.video_count %></td>
            <td class="td-actions">
              <button class="btn btn-sm btn-edit" onclick='editModel(<%= JSON.stringify(m) %>)' data-zh="编辑" data-en="Edit">编辑</button>
              <form method="POST" action="/admin/models/delete/<%= m.id %>" style="display:inline" onsubmit="return confirm('确定删除？')">
                <button type="submit" class="btn btn-sm btn-danger" data-zh="删除" data-en="Delete">删除</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<div class="modal-overlay" id="modelModal" style="display:none">
  <div class="modal">
    <div class="modal-header">
      <h3 id="modalTitle" data-zh="添加AI模型" data-en="Add AI Model">添加AI模型</h3>
      <button class="modal-close" onclick="closeModal()">×</button>
    </div>
    <form method="POST" action="/admin/models/save" class="admin-form">
      <input type="hidden" name="id" id="model_id">
      <div class="form-row">
        <div class="form-group">
          <label data-zh="模型名称" data-en="Model Name">模型名称</label>
          <input type="text" name="name" id="model_name" class="form-input" required>
        </div>
        <div class="form-group">
          <label data-zh="公司/组织" data-en="Company/Organization">公司/组织</label>
          <input type="text" name="company" id="model_company" class="form-input">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label data-zh="标识(slug)" data-en="Slug">标识(slug)</label>
          <input type="text" name="slug" id="model_slug" class="form-input" required placeholder="如: chatgpt" data-zh-placeholder="如: chatgpt" data-en-placeholder="e.g. chatgpt">
        </div>
        <div class="form-group">
          <label data-zh="排序" data-en="Order">排序</label>
          <input type="number" name="sort_order" id="model_sort" class="form-input" value="0">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label data-zh="图标(emoji)" data-en="Icon (emoji)">图标(emoji)</label>
          <input type="text" name="icon" id="model_icon" class="form-input" value="🤖">
        </div>
        <div class="form-group">
          <label data-zh="颜色" data-en="Color">颜色</label>
          <input type="color" name="color" id="model_color" class="form-input form-color" value="#8b5cf6">
        </div>
      </div>
      <div class="form-group">
        <label data-zh="描述" data-en="Description">描述</label>
        <input type="text" name="description" id="model_desc" class="form-input">
      </div>
      <div class="form-actions">
        <button type="button" class="btn btn-outline" onclick="closeModal()" data-zh="取消" data-en="Cancel">取消</button>
        <button type="submit" class="btn btn-primary">💾 <span data-zh="保存" data-en="Save">保存</span></button>
      </div>
    </form>
  </div>
</div>

<script>
function showAddForm() {
  document.getElementById('modalTitle').textContent = '添加AI模型';
  ['model_id','model_name','model_slug','model_company','model_icon','model_desc','model_sort'].forEach(id => document.getElementById(id).value = '');
  document.getElementById('model_icon').value = '🤖';
  document.getElementById('model_color').value = '#8b5cf6';
  document.getElementById('modelModal').style.display = 'flex';
}
function editModel(m) {
  document.getElementById('modalTitle').textContent = '编辑AI模型';
  document.getElementById('model_id').value = m.id;
  document.getElementById('model_name').value = m.name;
  document.getElementById('model_slug').value = m.slug;
  document.getElementById('model_company').value = m.company || '';
  document.getElementById('model_icon').value = m.icon;
  document.getElementById('model_color').value = m.color || '#8b5cf6';
  document.getElementById('model_desc').value = m.description || '';
  document.getElementById('model_sort').value = m.sort_order || 0;
  document.getElementById('modelModal').style.display = 'flex';
}
function closeModal() { document.getElementById('modelModal').style.display = 'none'; }
</script>

<%- include('../partials/admin-footer') %>
