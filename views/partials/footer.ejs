<script>
function copyEmail(e, email) {
  e.preventDefault();
  if (!email) email = e.currentTarget.getAttribute('data-email') || '524870347@qq.com';
  if (navigator.clipboard && navigator.clipboard.writeText) {
    navigator.clipboard.writeText(email).then(function() {
      var el = e.currentTarget;
      var orig = el.innerHTML;
      el.innerHTML = '<span class="social-icon">✅</span><span>已复制</span>';
      setTimeout(function() { el.innerHTML = orig; }, 2000);
    }).catch(function() { window.location.href = 'mailto:' + email; });
  } else {
    window.location.href = 'mailto:' + email;
  }
}
</script>
