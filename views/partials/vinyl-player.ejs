}
.vol-icon { font-size: 0.7rem; color: #b0a090; }
.volume-area input[type=range] {
  width: 70px;
  height: 3px;
  -webkit-appearance: none;
  appearance: none;
  background: rgba(196,30,58,0.1);
  border-radius: 2px;
  outline: none;
}
.volume-area input[type=range]::-webkit-slider-thumb {
