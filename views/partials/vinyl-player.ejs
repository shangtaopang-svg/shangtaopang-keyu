/* Mobile */
@media (max-width: 640px) {
  .vinyl-section { padding: 30px 12px 40px; }
  .turntable { width: 70vw; height: 70vw; }
  .tonearm { width: 90px; height: 100px; top: -8px; }
  .tonearm .arm-tube { width: 60px; }
  .tonearm .pivot { width: 24px; height: 24px; top: 6px; right: 6px; }
  .tonearm .pivot::after { width: 10px; height: 10px; }
