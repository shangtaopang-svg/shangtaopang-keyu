}
.pl-empty .pe-icon { font-size: 1.6rem; margin-bottom: 6px; opacity: 0.3; }

/* ===== Controls ===== */
.vinyl-controls {
  width: 100%;
  max-width: 500px;
  margin: 16px auto 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
}

.progress-area {
  width: 100%;
  display: flex;
  align-items: center;
  gap: 8px;
}
.pr-time {
  font-size: 0.55rem;
  color: #b0a090;
  min-width: 28px;
