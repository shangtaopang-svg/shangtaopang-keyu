}
</style>

<script>
(function() {
  var audio = new Audio();
  audio.volume = 0.7;
  var library = [];
  var currentIndex = -1;
  var isPlaying = false;

  // ===== Clock =====
  function updateClock() {
    var now = new Date();
    var h = now.getHours().toString().padStart(2,'0');
    var m = now.getMinutes().toString().padStart(2,'0');
    var el = document.getElementById('vinylClock');
    if (el) el.textContent = h + ':' + m;
  }
  updateClock();
  setInterval(updateClock, 5000);

  // ===== Init Library =====
  function initLibrary() {
    library = [];
    // --- Add your songs here ---
    // library.push({ file: '/music/your-song.mp3', name: 'Song Name', artist: 'Artist', duration: '?' });

    library.push({ file: '/music/1.mp3', name: '萨哈克回家', artist: '', duration: '?' });
    library.push({ file: '/music/liangzhu.mp3', name: '梁祝 (钢琴版)', artist: 'Wyatt Anderson / 中国民乐', duration: '?' });
    // --- Add more songs above ---

    renderPlaylist();
  }

  function renderPlaylist() {
    var container = document.getElementById('playlistItems');
    var countEl = document.getElementById('songCount');
    if (!container) return;

    if (!library.length) {
      container.innerHTML = '<div class="pl-empty"><div class="pe-icon">🎵</div><p data-zh="暂无音乐" data-en="No music yet">暂无音乐</p><p style="font-size:0.6rem;margin-top:4px;" data-zh="请将音乐文件放到 /music 目录下" data-en="Add music files to /music folder">请将音乐文件放到 /music 目录下</p></div>';
      if (countEl) countEl.textContent = '0 首';
      return;
    }

    if (countEl) countEl.textContent = library.length + ' 首';
    var html = '';
    library.forEach(function(song, i){
      var active = i === currentIndex ? ' active' : '';
      html += '<div class="pl-item' + active + '" onclick="playTrack(' + i + ')">';
      html += '<span class="pi-num">' + (i+1) + '</span>';
      html += '<div class="pi-info"><div class="pi-name">' + esc(song.name) + '</div><div class="pi-desc">' + esc(song.artist || '') + '</div></div>';
      html += '<span class="pi-dur">' + (song.duration || '') + '</span>';
      html += '</div>';
    });
    container.innerHTML = html;

    // Apply current language
    if (window.applyLang) {
      var lang = localStorage.getItem('pst-lang') || 'zh';
      window.applyLang(lang);
    }
  }

  // Expose functions globally
  window.playTrack = function(index) {
    if (index < 0 || index >= library.length) return;
    var song = library[index];
    if (!song || !song.file) return;
    currentIndex = index;
    audio.src = song.file;
    audio.load();
    audio.play().then(function(){ isPlaying = true; updateUI(); }).catch(function(){ isPlaying = false; updateUI(); });
  };

  window.togglePlay = function() {
    if (currentIndex < 0 || !library[currentIndex] || !library[currentIndex].file) return;
    if (audio.paused) {
      audio.play().then(function(){ isPlaying = true; updateUI(); }).catch(function(){});
    } else {
      audio.pause(); isPlaying = false; updateUI();
    }
  };

  window.prevTrack = function() {
    if (!library.length) return;
    playTrack(currentIndex - 1 < 0 ? library.length - 1 : currentIndex - 1);
  };

  window.nextTrack = function() {
    if (!library.length) return;
    playTrack(currentIndex + 1 >= library.length ? 0 : currentIndex + 1);
  };

  window.seekProgress = function(e) {
    var wrap = document.getElementById('progressWrap');
    if (!wrap) return;
    var rect = wrap.getBoundingClientRect();
    var pct = (e.clientX - rect.left) / rect.width;
    if (audio.duration) audio.currentTime = pct * audio.duration;
  };

  // Volume
  document.getElementById('volRange').addEventListener('input', function() {
    audio.volume = parseFloat(this.value);
  });

  // Progress bar click
  document.getElementById('progressWrap').addEventListener('click', function(e) {
    if (window.seekProgress) window.seekProgress(e);
  });

  // ===== UI =====
  function updateUI() {
    var vinyl = document.getElementById('vinylDisc');
    var tonearm = document.getElementById('tonearm');
    var playBtn = document.getElementById('playBtn');
    var titleEl = document.getElementById('nowTitle');
    var artistEl = document.getElementById('nowArtist');
    var labelEl = document.getElementById('labelSong');
    if (!vinyl || !tonearm || !playBtn) return;

    if (isPlaying && !audio.paused) {
      vinyl.classList.add('playing'); vinyl.classList.remove('paused');
      playBtn.textContent = '⏸';
      tonearm.style.transition = 'transform 0.5s ease';
      tonearm.style.transform = 'translateY(-18px) rotate(15deg)';
      clearTimeout(window._armTimer);
      window._armTimer = setTimeout(function(){
        tonearm.style.transition = 'transform 0.35s ease';
        tonearm.style.transform = 'translateY(0) rotate(15deg)';
      }, 550);
    } else {
      vinyl.classList.add('paused'); vinyl.classList.remove('playing');
      playBtn.textContent = '▶';
      tonearm.style.transition = 'transform 0.3s ease';
      tonearm.style.transform = 'translateY(-18px) rotate(15deg)';
      clearTimeout(window._armTimer);
      window._armTimer = setTimeout(function(){
        tonearm.style.transition = 'transform 0.5s ease';
        tonearm.style.transform = 'translateY(-18px) rotate(-45deg)';
      }, 350);
    }

    if (currentIndex >= 0 && library[currentIndex]) {
      var song = library[currentIndex];
      if (titleEl) titleEl.textContent = song.name || '——';
      if (artistEl) artistEl.textContent = song.artist || '';
      if (labelEl) labelEl.textContent = song.name ? song.name.slice(0,8) : '下枫槎谢氏';
    }
    renderPlaylist();
  }

  // Audio events
  audio.addEventListener('timeupdate', function(){
    var fill = document.getElementById('progressFill');
    var cur = document.getElementById('curTime');
    var dur = document.getElementById('durTime');
    if (audio.duration && fill) {
      fill.style.width = (audio.currentTime / audio.duration * 100) + '%';
      if (cur) cur.textContent = formatTime(audio.currentTime);
      if (dur) dur.textContent = formatTime(audio.duration);
    }
  });
  audio.addEventListener('ended', function(){ nextTrack(); });
  audio.addEventListener('play', function(){ isPlaying = true; updateUI(); });
  audio.addEventListener('pause', function(){ isPlaying = false; updateUI(); });

  // Utility
  function formatTime(sec) {
    if (!sec || isNaN(sec)) return '0:00';
    var m = Math.floor(sec / 60);
    var s = Math.floor(sec % 60);
    return m + ':' + (s < 10 ? '0' : '') + s;
  }
  function esc(t) {
    if (!t) return '';
    return String(t).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  // Init tonearm position
  var ta = document.getElementById('tonearm');
  if (ta) {
    ta.style.transition = 'none';
    ta.style.transform = 'translateY(-18px) rotate(-45deg)';
    ta.offsetHeight;
    ta.style.transition = 'transform 0.9s cubic-bezier(0.34, 1.2, 0.64, 1)';
  }

  initLibrary();
})();
</script>
