  gap: 16px;
}
.ctrl-btn {
  width: 34px; height: 34px;
  border-radius: 50%;
  border: 1px solid #d4c8b8;
  background: #ffffff;
  color: #8a7030;
  font-size: 0.9rem;
  cursor: pointer;
  transition: all 0.2s;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Noto Serif SC', serif;
}
.ctrl-btn:hover {
  background: #f5ede0;
  border-color: #c41e3a;
  color: #c41e3a;
}
.ctrl-play {
  width: 42px; height: 42px;
  background: linear-gradient(135deg, #c41e3a, #a81830);
