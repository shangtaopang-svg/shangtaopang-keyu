}
.pl-item:hover { background: rgba(0,0,0,0.02); }
.pl-item.active { background: rgba(196,30,58,0.06); border-left: 2px solid #c41e3a; }
.pl-item .pi-num {
  font-size: 0.55rem;
  color: #d0c8b8;
  min-width: 18px;
  text-align: right;
}
.pl-item .pi-info { flex: 1; min-width: 0; }
.pl-item .pi-name {
