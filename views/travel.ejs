<%- include('partials/header') %>
<link rel="stylesheet" href="/css/leaflet.css" />
<script src="/js/leaflet.min.js" onload="window.leafletReady = (typeof L !== 'undefined')"></script>

<section class="page-header">
  <div class="container">
    <h1 class="page-title" data-zh="🗺️ 出行轨迹" data-en="🗺️ Travel Map">🗺️ 出行轨迹</h1>
    <p class="page-desc" data-zh="近2年足迹 · 不出差就在宁海" data-en="Footprints of the past 2 years">近2年足迹 · 不出差就在宁海</p>
  </div>
</section>

<section class="section" style="padding-top:0">
  <div class="container">
    <!-- 统计卡片 -->
    <div class="travel-stats" style="margin-bottom:16px">
      <div class="ts-card"><span class="ts-num"><%= totalTrips %></span><span class="ts-label" data-zh="出行次数" data-en="Trips">出行次数</span></div>
      <div class="ts-card"><span class="ts-num"><%= cities.length %></span><span class="ts-label" data-zh="到访城市" data-en="Cities">到访城市</span></div>
      <div class="ts-card"><span class="ts-num"><%= totalDays %></span><span class="ts-label" data-zh="出行天数" data-en="Days">出行天数</span></div>
      <div class="ts-card"><span class="ts-num" style="font-size:0.9rem">宁海</span><span class="ts-label" data-zh="常驻地" data-en="Home Base">常驻地</span></div>
    </div>

    <!-- 地图 -->
    <div class="travel-map-wrap">
      <div id="travelMap" style="width:100%;height:480px;border-radius:12px;border:1px solid var(--border);position:relative;z-index:1"></div>
      <div class="map-legend">
        <span class="ml-dot" style="background:#22d3ee"></span><span data-zh="常驻地" data-en="Home Base"> 常驻地</span>
        <span class="ml-dot" style="background:#f97316"></span><span data-zh="到访城市" data-en="Cities Visited"> 到访城市</span>
        <span class="ml-dot" style="background:linear-gradient(90deg,#22d3ee,#f97316,#34d399,#f472b6)"></span><span data-zh="多彩路线" data-en="Colorful Routes"> 多彩路线</span>
      </div>
    </div>

    <!-- 月度热度 -->
    <div class="travel-section" style="margin-top:16px">
      <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px">
        <h3 style="margin:0" data-zh="📅 月度出行" data-en="📅 Monthly Trips">📅 月度出行</h3>
        <div style="display:flex;gap:6px;align-items:center">
          <select id="yearSelect" onchange="switchYear(this.value)" style="padding:4px 10px;background:var(--bg);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:0.82rem">
            <% const curYear = new Date().getFullYear(); for (let y = curYear - 2; y <= curYear; y++) { %><option value="<%= y %>" <%= y === curYear ? 'selected' : '' %> data-zh="<%= y %>年" data-en="<%= y %>"><%= y %>年</option><% } %>
          </select>
          <span id="monthFilter" style="display:none;font-size:0.78rem;color:var(--primary);cursor:pointer" onclick="clearMonthFilter()" data-zh="✕ 清除" data-en="✕ Clear">✕ 清除</span>
        </div>
      </div>
      <div class="month-grid" id="monthGrid" style="margin-top:12px">
        <% const now = new Date(); for (let m = 1; m <= 12; m++) { const ms = String(m).padStart(2,'0'); const key = curYear + '-' + ms; const km = typeof monthKm !== 'undefined' ? (monthKm[key] || 0) : 0; %>
          <div class="month-cell" data-month="<%= key %>" onclick="filterMonth('<%= key %>')" style="background:<%= months[key] ? '#22d3ee' : 'var(--bg)' %>;color:<%= months[key] ? '#fff' : 'var(--text-muted)' %>;cursor:pointer;opacity:1;border:<%= months[key] ? 'none' : '1px solid var(--border)' %>">
            <span style="font-size:0.75rem;font-weight:<%= months[key] ? '600' : '400' %>" data-zh="<%= m %>月" data-en="Month <%= m %>"><%= m %>月</span>
            <small style="font-size:0.65rem;opacity:<%= months[key] ? '1' : '0.5' %>" data-zh="<%= months[key] || 0 %>次" data-en="<%= months[key] || 0 %> trips"><%= months[key] || 0 %>次</small>
            <% if (km > 0) { %><small style="font-size:0.55rem;opacity:0.8"><%= km %>km</small><% } %>
          </div>
        <% } %>
      </div>
    </div>

    <!-- 时间线 -->
    <div class="travel-section">
      <h3 data-zh="📜 出行记录" data-en="📜 Travel Records">📜 出行记录</h3>
      <% if (records.length === 0) { %>
        <div class="empty-state"><span class="empty-icon">🗺️</span><h3 data-zh="暂无出行记录" data-en="No travel records yet">暂无出行记录</h3><p data-zh="在后台添加出行后，地图和时间线将自动更新" data-en="Add trips in the admin panel to update the map and timeline">在后台添加出行后，地图和时间线将自动更新</p></div>
      <% } else { %>
        <div class="travel-timeline">
          <% records.forEach((r, i) => { %>
          <div class="tl-entry">
            <div class="tl-dot-line">
              <span class="tld-dot" style="background:<%= r.transport === 'plane' ? '#f97316' : '#22d3ee' %>"></span>
              <% if (i < records.length - 1) { %><span class="tld-line"></span><% } %>
            </div>
            <div class="tl-card" onmouseenter="highlightRoute(<%= i %>)" onmouseleave="unhighlightRoute()">
              <div class="tlc-header">
                <span class="tlc-city"><%= r.departure || '宁海' %> → <%= r.destination %></span>
                <span class="tlc-date"><%= r.start_date %><%= r.end_date && r.end_date !== r.start_date ? ' ~ ' + r.end_date : '' %></span>
              </div>
              <% if (r.purpose) { %><p class="tlc-purpose">📋 <%= r.purpose %></p><% } %>
              <div class="tlc-meta">
                <span><%= r.transport === 'plane' ? '✈️' : r.transport === 'train' ? '🚄' : '🚗' %> <%= r.vehicle || '' %></span>
                <% if (r.depart_time) { %><span>🕐 <%= r.depart_time %><%= r.arrive_time ? '→'+r.arrive_time : '' %></span><% } %>
                <% if (r.distance) { %><span>📏 <%= r.distance %>km</span><% } %>
                <% if (r.notes) { %><span>💬 <%= r.notes %></span><% } %>
              </div>
              <% if (r.segments) { try { var segs = JSON.parse(r.segments); if (segs.length > 0) { %>
              <div style="margin-top:6px;padding-top:6px;border-top:1px dashed var(--border);font-size:0.75rem;color:var(--text-muted)" data-zh="🔄 换乘<%= segs.length %>次：" data-en="🔄 <%= segs.length %> transfers:">
                🔄 换乘<%= segs.length %>次：
                <% segs.forEach(function(s){ %>
                  <span><%= s.from %>→<%= s.to %>(<%= s.vehicle||'' %>)</span>
                <% }) %>
              </div>
              <% } } catch(e){} } %>
            </div>
          </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>
</section>

<script>
// 城市坐标映射 (宁海 + 常见出差地)
const CITY_COORDS = {
